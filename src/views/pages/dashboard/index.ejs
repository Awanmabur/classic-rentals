              <% if (recentListings.length) { %>
                <% recentListings.forEach((item) => { %>
                  <tr>
                    <td><strong><%= item.title %></strong><br><span class="muted"><%= fmtMoney(item.price?.amount, item.price?.currency, item.price?.unit) %></span></td>
                    <td><%= item.category %></td>
                    <td><%= [item.location?.area, item.location?.city].filter(Boolean).join(', ') || '-' %></td>
                    <td><%= listingStatusLabel(item.status) %></td>
                    <td><a class="text-link" href="/listings/<%= item.slug %>">View</a></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="5">No listings found in this workspace yet.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
