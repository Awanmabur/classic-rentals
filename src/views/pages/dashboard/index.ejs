      <section class="card">
        <div class="section-head">
          <div>
            <h4>Live Table Snapshot</h4><span>Recent records from the current dashboard scope</span>
          </div>
          <a class="ghost-btn" href="/dashboard/manage-listings">Open module</a>
        </div>
        <div class="table-shell">
          <table>
            <thead>
              <tr>
                <th>Listing</th>
                <th>Category</th>
                <th>Location</th>
