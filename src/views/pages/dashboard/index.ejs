  <script>
    const appShell = document.getElementById('appShell');
    const sidebar = document.getElementById('sidebar');
    const menuBtn = document.getElementById('menuBtn');
    const collapseBtn = document.getElementById('collapseBtn');
    const themeBtn = document.getElementById('themeBtn');
    const sidebarThemeBtn = document.getElementById('sidebarThemeBtn');
    const sidebarTooltip = document.getElementById('sidebarTooltip');
    const navLinks = Array.from(document.querySelectorAll('.nav-link'));
    const statusFilter = document.getElementById('statusFilter');
    const categoryFilter = document.getElementById('categoryFilter');
    const propertySearch = document.getElementById('propertySearch');
    const searchInput = document.getElementById('searchInput');
    const propertyCards = Array.from(document.querySelectorAll('.property-card'));

    function isMobile() { return window.innerWidth <= 1024; }
    function syncLayoutGuards() {
      document.documentElement.style.overflowX = 'hidden';
      document.body.style.overflowX = 'hidden';
      sidebar.style.overflowX = isMobile() ? 'hidden' : 'visible';
    }
    function hideSidebarTooltip() { sidebarTooltip.classList.remove('show'); }
    function showSidebarTooltip(target) {
      if (!appShell.classList.contains('sidebar-collapsed') || isMobile()) return hideSidebarTooltip();
      const rect = target.getBoundingClientRect();
      sidebarTooltip.textContent = target.dataset.label || '';
      sidebarTooltip.style.left = `${rect.right + 14}px`;
      sidebarTooltip.style.top = `${rect.top + rect.height / 2}px`;
      sidebarTooltip.classList.add('show');
    }
    function updateIcons() {
      if (isMobile()) {
        menuBtn.textContent = sidebar.classList.contains('show') ? '✕' : '☰';
        collapseBtn.textContent = sidebar.classList.contains('show') ? '✕' : '>';
      } else {
        menuBtn.textContent = '☰';
        collapseBtn.textContent = appShell.classList.contains('sidebar-collapsed') ? '>' : '<';
      }
    }
    function openSidebar() { sidebar.classList.add('show'); syncLayoutGuards(); updateIcons(); }
    function closeSidebar() { sidebar.classList.remove('show'); syncLayoutGuards(); updateIcons(); }
    menuBtn?.addEventListener('click', () => { if (!isMobile()) return; sidebar.classList.contains('show') ? closeSidebar() : openSidebar(); });
    collapseBtn?.addEventListener('click', () => {
      if (isMobile()) return sidebar.classList.contains('show') ? closeSidebar() : openSidebar();
      appShell.classList.toggle('sidebar-collapsed'); hideSidebarTooltip(); updateIcons();
    });
    navLinks.forEach((link) => {
      link.addEventListener('mouseenter', () => showSidebarTooltip(link));
      link.addEventListener('mouseleave', hideSidebarTooltip);
      link.addEventListener('focus', () => showSidebarTooltip(link));
      link.addEventListener('blur', hideSidebarTooltip);
    });
    function filterProperties() {
      const status = statusFilter?.value || 'all';
      const category = categoryFilter?.value || 'all';
      const search = (propertySearch?.value || searchInput?.value || '').trim().toLowerCase();
      propertyCards.forEach((card) => {
        const matchStatus = status === 'all' || card.dataset.status === status;
        const matchCategory = category === 'all' || card.dataset.category === category;
        const matchSearch = !search || card.dataset.name.includes(search);
        card.style.display = matchStatus && matchCategory && matchSearch ? 'grid' : 'none';
      });
    }
    statusFilter?.addEventListener('change', filterProperties);
    categoryFilter?.addEventListener('change', filterProperties);
    propertySearch?.addEventListener('input', filterProperties);
    searchInput?.addEventListener('input', filterProperties);

    const labels = <%- JSON.stringify(last7Labels) %>;
    const pointsRevenue = <%- JSON.stringify(listingPoints) %>;
    const pointsOutstanding = <%- JSON.stringify(inquiryPoints) %>;
    const canvas = document.getElementById('revenueChart');
    const ctx = canvas?.getContext('2d');

    function roundedRect(x, y, w, h, r) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + w, y, x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x, y + h, r);
      ctx.arcTo(x, y + h, x, y, r);
      ctx.arcTo(x, y, x + w, y, r);
      ctx.closePath();
    }
    function drawLine(data, color, fill = false) {
      const rect = canvas.getBoundingClientRect();
      const width = rect.width; const height = rect.height;
      const padX = 14; const padTop = 14; const padBottom = 48;
      const max = Math.max(6, ...pointsRevenue, ...pointsOutstanding, 1);
      const safeData = Array.isArray(data) && data.length ? data : [0];
      const stepX = (width - padX * 2) / Math.max(1, safeData.length - 1);
      const pts = safeData.map((v, i) => ({ x: padX + stepX * i, y: padTop + ((max - v) / max) * (height - padTop - padBottom) }));
      if (!pts.length) return;
      if (fill && pts.length > 1) {
        const gradient = ctx.createLinearGradient(0, 0, 0, height);
        gradient.addColorStop(0, 'rgba(205,119,0,0.16)');
        gradient.addColorStop(1, 'rgba(205,119,0,0.01)');
        ctx.beginPath(); ctx.moveTo(pts[0].x, pts[0].y);
        for (let i = 1; i < pts.length; i++) { const prev = pts[i - 1], curr = pts[i], cx = (prev.x + curr.x) / 2; ctx.quadraticCurveTo(prev.x, prev.y, cx, (prev.y + curr.y) / 2); }
        const last = pts[pts.length - 1];
        ctx.lineTo(last.x, height - padBottom + 2); ctx.lineTo(pts[0].x, height - padBottom + 2); ctx.closePath(); ctx.fillStyle = gradient; ctx.fill();
      }
      ctx.beginPath(); ctx.moveTo(pts[0].x, pts[0].y);
      for (let i = 1; i < pts.length; i++) { const prev = pts[i - 1], curr = pts[i], cx = (prev.x + curr.x) / 2; ctx.quadraticCurveTo(prev.x, prev.y, cx, (prev.y + curr.y) / 2); }
      ctx.strokeStyle = color; ctx.lineWidth = 2.5; ctx.lineCap = 'round'; ctx.lineJoin = 'round'; ctx.stroke();
      const labelColor = document.body.classList.contains('dark-mode') ? '#94a3b8' : '#6b7280';
      pts.forEach((p, i) => {
        ctx.beginPath(); ctx.arc(p.x, p.y, 3.5, 0, Math.PI * 2); ctx.fillStyle = '#fff'; ctx.fill(); ctx.lineWidth = 2; ctx.strokeStyle = color; ctx.stroke();
        ctx.fillStyle = labelColor; ctx.font = '12px Poppins'; ctx.textAlign = 'center'; ctx.fillText(labels[i] || '', p.x, height - 23);
      });
    }
    function drawChart() {
      if (!canvas || !ctx) return;
      const rect = canvas.getBoundingClientRect(); const width = rect.width; const height = rect.height;
      ctx.clearRect(0, 0, width, height);
      roundedRect(0, 0, width, height, 18); ctx.fillStyle = getComputedStyle(document.body).getPropertyValue('--panel').trim() || '#fff'; ctx.fill();
      const rows = 4; const padX = 14; const padTop = 14; const padBottom = 48; const chartH = height - padTop - padBottom;
      const gridColor = document.body.classList.contains('dark-mode') ? 'rgba(148,163,184,0.14)' : '#edf2f7';
      const outstandingColor = document.body.classList.contains('dark-mode') ? '#64748b' : '#d1d5db';
      for (let i = 0; i <= rows; i++) { const y = padTop + (chartH / rows) * i; ctx.beginPath(); ctx.moveTo(padX, y); ctx.lineTo(width - padX, y); ctx.strokeStyle = gridColor; ctx.lineWidth = 1; ctx.stroke(); }
      const hasRevenue = Array.isArray(pointsRevenue) && pointsRevenue.some(v => Number(v) > 0);
      const hasOutstanding = Array.isArray(pointsOutstanding) && pointsOutstanding.some(v => Number(v) > 0);
      if (!hasRevenue && !hasOutstanding) {
        ctx.fillStyle = document.body.classList.contains('dark-mode') ? '#94a3b8' : '#6b7280';
        ctx.font = '600 13px Poppins';
        ctx.textAlign = 'center';
        ctx.fillText('No chart data yet', width / 2, height / 2);
        return;
      }
      if (hasOutstanding) drawLine(pointsOutstanding, outstandingColor);
      if (hasRevenue) drawLine(pointsRevenue, '#cd7700', true);
    }
    function resizeCanvas() {
      if (!canvas || !ctx) return;
      const dpr = window.devicePixelRatio || 1; const rect = canvas.getBoundingClientRect(); if (!rect.width || !rect.height) return;
      canvas.width = Math.max(1, rect.width * dpr); canvas.height = Math.max(1, rect.height * dpr); ctx.setTransform(1, 0, 0, 1, 0, 0); ctx.scale(dpr, dpr); drawChart();
    }
    function toggleTheme() { document.body.classList.toggle('dark-mode'); syncLayoutGuards(); requestAnimationFrame(() => { resizeCanvas(); setTimeout(resizeCanvas, 100); }); }
    themeBtn?.addEventListener('click', toggleTheme);
    sidebarThemeBtn?.addEventListener('click', (e) => { e.preventDefault(); toggleTheme(); });
    window.addEventListener('resize', () => { syncLayoutGuards(); if (!isMobile()) closeSidebar(); hideSidebarTooltip(); updateIcons(); requestAnimationFrame(() => { resizeCanvas(); setTimeout(resizeCanvas, 80); }); });
    syncLayoutGuards(); updateIcons(); filterProperties(); requestAnimationFrame(() => { resizeCanvas(); setTimeout(resizeCanvas, 100); });
  </script>
</body>
