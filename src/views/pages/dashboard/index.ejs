<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Dashboard' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #cd7700;
      --primary-soft: rgba(205, 119, 0, 0.12);
      --bg: #f5f7fb;
      --panel: #ffffff;
      --panel-soft: #f8fafc;
      --text: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --success: #16a34a;
      --warning: #d97706;
      --danger: #dc2626;
      --info: #2563eb;
      --shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
      --shadow-soft: 0 8px 18px rgba(15, 23, 42, 0.04);
      --radius-xl: 22px;
      --radius-lg: 18px;
      --radius-pill: 999px;
      --sidebar-w: 252px;
      --sidebar-mini: 82px;
    }

    body.dark-mode {
      --bg: #0b1220;
      --panel: #111827;
      --panel-soft: #0f172a;
      --text: #e5e7eb;
      --muted: #94a3b8;
      --line: rgba(148, 163, 184, 0.18);
      --primary-soft: rgba(205, 119, 0, 0.16);
      --shadow: 0 16px 32px rgba(0, 0, 0, 0.28);
      --shadow-soft: 0 8px 20px rgba(0, 0, 0, 0.22);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { width: 100%; max-width: 100%; overflow-x: hidden; }
    body { font-family: 'Poppins', sans-serif; background: var(--bg); color: var(--text); font-size: 13px; transition: background .25s ease, color .25s ease; }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    button, input, select, textarea { font: inherit; }
    .app { min-height: 100vh; background: var(--bg); }
    .sidebar {
      position: fixed; left: 0; top: 0; bottom: 0; width: var(--sidebar-w);
      background: color-mix(in srgb, var(--panel) 96%, transparent); border-right: 1px solid var(--line);
      backdrop-filter: blur(12px); display: flex; flex-direction: column; gap: 14px; padding: 14px 10px;
      overflow-y: auto; overflow-x: visible; z-index: 100; transition: width .25s ease, transform .25s ease;
      scrollbar-width: thin; scrollbar-color: rgba(156, 163, 175, 0.45) transparent;
    }
    body.dark-mode .sidebar { scrollbar-color: rgba(30, 41, 59, .95) rgba(15, 23, 42, .9); }
    .sidebar::-webkit-scrollbar { width: 8px; }
    .sidebar::-webkit-scrollbar-track { background: transparent; }
    .sidebar::-webkit-scrollbar-thumb { background: rgba(156, 163, 175, .45); border-radius: 999px; }
    body.dark-mode .sidebar::-webkit-scrollbar-track { background: rgba(15, 23, 42, .9); }
    body.dark-mode .sidebar::-webkit-scrollbar-thumb { background: rgba(30, 41, 59, .95); }
    .main { margin-left: var(--sidebar-w); min-width: 0; width: calc(100% - var(--sidebar-w)); padding: 14px; display: grid; gap: 14px; transition: margin-left .25s ease, width .25s ease; }
    .app.sidebar-collapsed .sidebar { width: var(--sidebar-mini); }
    .app.sidebar-collapsed .main { margin-left: var(--sidebar-mini); width: calc(100% - var(--sidebar-mini)); }
    .sidebar-head { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
    .brand { flex: 1; min-width: 0; display: flex; align-items: center; gap: 9px; padding: 0; background: transparent; border-radius: 0; border: 0; box-shadow: none; }
    .brand-logo { width: 40px; height: 40px; border-radius: 14px; display: grid; place-items: center; background: var(--primary); color: #fff; font-weight: 800; box-shadow: var(--shadow-soft); flex-shrink: 0; }
    .brand h1 { font-size: .88rem; line-height: 1.1; white-space: nowrap; }
    .brand p { margin-top: 2px; color: var(--muted); font-size: .68rem; white-space: nowrap; }
    .collapse-btn, .menu-btn, .icon-btn, .theme-btn, .view-btn {
      width: 34px; height: 34px; border-radius: var(--radius-pill); border: 1px solid var(--line); background: var(--panel); color: var(--text);
      display: grid; place-items: center; cursor: pointer; box-shadow: var(--shadow-soft); transition: .2s ease; flex-shrink: 0;
    }
    .collapse-btn:hover, .menu-btn:hover, .icon-btn:hover, .theme-btn:hover, .view-btn:hover, .nav-link:hover, .primary-btn:hover, .ghost-btn:hover { transform: translateY(-1px); }
    .nav-group { display: grid; gap: 6px; }
    .nav-title { padding: 0 10px; color: #9ca3af; text-transform: uppercase; letter-spacing: .08em; font-size: .66rem; margin-top: 4px; margin-bottom: 2px; }
    .nav-link {
      position: relative; width: 100%; border: 0; background: transparent; color: var(--text); display: flex; align-items: center; gap: 9px; min-height: 42px;
      padding: 7px 10px; border-radius: var(--radius-pill); cursor: pointer; text-align: left; transition: .2s ease;
    }
    .nav-link:hover { background: rgba(17, 24, 39, .04); }
    .nav-link.active { background: rgba(205, 119, 0, .12); color: var(--primary); font-weight: 700; }
    .nav-icon { width: 30px; height: 30px; border-radius: var(--radius-pill); background: var(--panel); border: 1px solid var(--line); display: grid; place-items: center; box-shadow: var(--shadow-soft); flex-shrink: 0; font-size: 12px; }
    .nav-label { font-size: .8rem; white-space: nowrap; }
    .sidebar-card { margin-top: auto; background: #111827; color: #fff; padding: 14px; border-radius: 18px; box-shadow: var(--shadow); border: 1px solid transparent; }
    .chip { display: inline-flex; align-items: center; gap: 7px; padding: 5px 9px; border-radius: var(--radius-pill); background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.08); font-size: .64rem; margin-bottom: 9px; }
    .sidebar-card h3 { font-size: .88rem; margin-bottom: 5px; }
    .sidebar-card p { color: rgba(255,255,255,.74); font-size: .72rem; line-height: 1.55; margin-bottom: 10px; }
    .primary-btn, .ghost-btn, .sidebar-card button { border: 0; border-radius: var(--radius-pill); padding: 8px 14px; min-height: 36px; font-size: .76rem; font-weight: 700; cursor: pointer; transition: .2s ease; }
    .primary-btn { color: #fff; background: var(--primary); box-shadow: var(--shadow-soft); }
    .ghost-btn { color: var(--text); background: var(--panel); border: 1px solid var(--line); }
    .sidebar-card button { width: 100%; color: #111827; background: #fff; }
    .topbar { display: grid; grid-template-columns: auto minmax(140px, 1fr) auto; align-items: center; gap: 12px; min-width: 0; }
    .topbar-left { display: flex; align-items: center; gap: 10px; min-width: 0; }
    .page-title h2 { font-size: 1.22rem; line-height: 1.1; margin-bottom: 3px; }
    .page-title p { color: var(--muted); font-size: .76rem; }
    .menu-btn { display: none; margin-left: auto; }
    .topbar-center { display: flex; align-items: center; justify-content: center; gap: 6px; min-width: 0; }
    .search { position: relative; min-width: 140px; max-width: 260px; width: 100%; }
    .search input, .filter-row select, .filter-row input {
      width: 100%; outline: none; border: 1px solid var(--line); background: var(--panel); color: var(--text); border-radius: 16px; padding: 10px 12px; font-size: .74rem; box-shadow: var(--shadow-soft); transition: .2s ease;
    }
    .search input { padding-left: 30px; min-height: 32px; border-radius: var(--radius-pill); padding-top: 7px; padding-bottom: 7px; }
    .search input:focus, .filter-row select:focus, .filter-row input:focus { border-color: rgba(205,119,0,.32); box-shadow: 0 0 0 4px rgba(205,119,0,.08); }
    .search-icon { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); color: #9ca3af; font-size: 12px; pointer-events: none; }
    .topbar-right { display: flex; align-items: center; justify-content: flex-end; gap: 6px; flex-wrap: nowrap; }
    .icon-btn { position: relative; font-size: 12px; }
    .dot { position: absolute; right: 7px; top: 7px; width: 7px; height: 7px; border-radius: 50%; background: var(--danger); border: 2px solid var(--panel); }
    .hero, .dashboard-grid, .summary-list, .property-list, .payment-list, .tenant-list, .activity-list, .stack, .stats-grid { display: grid; gap: 14px; min-width: 0; }
    .hero { grid-template-columns: 1.3fr .9fr; }
    .dashboard-grid { grid-template-columns: 1.12fr .88fr; }
    .card, .hero-card { background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius-xl); box-shadow: var(--shadow); position: relative; min-width: 0; }
    .card { padding: 16px; }
    .hero-card { overflow: hidden; padding: 18px; min-height: 220px; }
    .section-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; }
    .section-head h4 { font-size: .92rem; }
    .section-head span { color: var(--muted); font-size: .7rem; }
    .tag, .status, .meta span, .hero-badge, .trend { border-radius: var(--radius-pill); font-size: .64rem; }
    .tag { padding: 5px 9px; background: rgba(17,24,39,.04); color: var(--muted); }
    .hero-badge { display: inline-flex; align-items: center; gap: 7px; padding: 6px 10px; font-weight: 700; color: var(--primary); background: var(--primary-soft); margin-bottom: 10px; }
    .hero h3 { font-size: 1.34rem; line-height: 1.2; margin-bottom: 8px; max-width: 460px; }
    .hero p, .muted { color: var(--muted); font-size: .76rem; line-height: 1.6; }
    .hero-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
    .hero-stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }
    .mini-stat, .stat-card, .summary-item, .property-card, .list-row { border-radius: 16px; min-width: 0; padding: 12px; border: 1px solid var(--line); background: var(--panel-soft); box-shadow: var(--shadow-soft); }
    .mini-stat small, .summary-item small, .stat-card p { display: block; color: var(--muted); font-size: .68rem; }
    .mini-stat strong { font-size: .98rem; }
    .summary-item { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
    .summary-item b { display: block; font-size: .78rem; margin-bottom: 2px; }
    .amount { font-size: .78rem; font-weight: 700; }
    .analytics-card { display: grid; grid-template-rows: auto auto 1fr; min-height: 620px; }
    .stats-grid { margin-top: 12px; grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .stat-card { min-height: 100px; display: flex; flex-direction: column; justify-content: space-between; }
    .stat-top { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
    .stat-icon { width: 36px; height: 36px; border-radius: var(--radius-pill); display: grid; place-items: center; background: var(--primary-soft); color: var(--primary); font-size: 13px; }
    .trend { padding: 4px 7px; font-weight: 700; }
    .up { color: var(--success); background: rgba(22,163,74,.09); }
    .down { color: var(--danger); background: rgba(220,38,38,.08); }
    .stat-card h5 { font-size: 1rem; line-height: 1.2; margin: 8px 0 2px; }
    .chart-legend { display: flex; align-items: center; flex-wrap: wrap; gap: 10px; color: var(--muted); font-size: .68rem; }
    .legend-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 5px; vertical-align: middle; }
    .chart-wrap { margin-top: 14px; height: 100%; min-height: 420px; position: relative; width: 100%; }
    .chart-wrap canvas { display: block; width: 100% !important; height: 100% !important; }
    .filter-row { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px; margin-bottom: 18px; }
    .filter-row > * { flex: 1 1 160px; }
    .property-list { margin-top: 6px; gap: 12px; }
    .property-card { display: grid; grid-template-columns: 96px 1fr auto; gap: 10px; align-items: center; transition: .2s ease; }
    .property-card:hover { transform: translateY(-1px); }
    .property-card-link { cursor: pointer; }
    .property-card-link * { cursor: pointer; }
    .property-card-link:focus-visible { outline: 3px solid rgba(205, 119, 0, .22); outline-offset: 2px; }
    .property-thumb { height: 76px; border-radius: 14px; overflow: hidden; background: #e5e7eb; }
    .property-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .property-info h5 { font-size: .82rem; margin-bottom: 3px; }
    .property-info p, .list-main p { color: var(--muted); font-size: .68rem; line-height: 1.5; }
    .meta { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 7px; }
    .meta span { padding: 5px 8px; background: rgba(17,24,39,.04); color: var(--muted); }
    .property-side { min-width: 90px; text-align: right; }
    .property-side strong { display: block; font-size: .82rem; margin-bottom: 6px; }
    .status { display: inline-flex; align-items: center; gap: 5px; padding: 5px 9px; font-weight: 700; }
    .status::before { content:""; width:6px; height:6px; border-radius:50%; background: currentColor; }
    .status.occupied { color: var(--success); background: rgba(22,163,74,.09); }
    .status.pending { color: var(--warning); background: rgba(217,119,6,.09); }
    .status.vacant { color: var(--info); background: rgba(37,99,235,.09); }
    .progress-card { overflow: hidden; padding: 0; }
    .progress-top { padding: 16px 16px 12px; }
    .progress-body { display: grid; gap: 10px; padding: 0 16px 16px; }
    .progress-row { display: grid; gap: 6px; }
    .progress-label { display: flex; justify-content: space-between; gap: 8px; font-size: .74rem; }
    .progress-bar { height: 8px; border-radius: var(--radius-pill); background: rgba(148,163,184,.18); overflow: hidden; }
    .progress-bar span { display: block; height: 100%; border-radius: inherit; background: var(--primary); }
    .list-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .list-main { display: flex; align-items: center; gap: 9px; min-width: 0; }
    .avatar { width: 36px; height: 36px; border-radius: var(--radius-pill); display: grid; place-items: center; background: #1f2937; color: #fff; font-weight: 700; font-size: .68rem; flex-shrink: 0; }
    .list-main h5 { font-size: .78rem; margin-bottom: 2px; }
    .list-side { text-align: right; flex-shrink: 0; }
    .list-side strong { display: block; font-size: .76rem; margin-bottom: 3px; }
    .list-side small { color: var(--muted); font-size: .66rem; }
    .table-shell { overflow: auto; border: 1px solid var(--line); border-radius: 18px; }
    table { width: 100%; border-collapse: collapse; min-width: 680px; }
    th, td { padding: 12px 14px; text-align: left; font-size: .74rem; border-bottom: 1px solid var(--line); }
    th { color: var(--muted); font-weight: 700; background: var(--panel-soft); }
    td { background: var(--panel); }
    .ring-wrap { display:flex; justify-content:center; padding:16px 0 6px; }
    .ring { width: 168px; height: 168px; border-radius: 50%; background: conic-gradient(var(--primary) 0 calc(var(--ring-angle, 72) * 1%), rgba(17,24,39,.08) 0); position: relative; }
    .ring::before { content:""; position:absolute; inset:16px; background: var(--panel); border-radius:50%; box-shadow: inset 0 0 0 1px var(--line); }
    .ring-center { position:absolute; inset:0; display:grid; place-items:center; text-align:center; z-index:2; padding:20px; }
    .ring-center strong { display:block; font-size:1.7rem; }
    .ring-center span { color:var(--muted); font-size:.72rem; }
    .sidebar-tooltip { position: fixed; left: 0; top: 0; transform: translateY(-50%); background: #111827; color: #fff; padding: 8px 11px; border-radius: 12px; font-size: .68rem; font-weight: 600; white-space: nowrap; box-shadow: 0 12px 30px rgba(15, 23, 42, .22); opacity: 0; visibility: hidden; pointer-events: none; z-index: 20000; transition: opacity .15s ease, visibility .15s ease; }
    .sidebar-tooltip.show { opacity: 1; visibility: visible; }
    .text-link { color: var(--primary); font-weight: 700; }
    .app.sidebar-collapsed .brand-text, .app.sidebar-collapsed .nav-title, .app.sidebar-collapsed .nav-label, .app.sidebar-collapsed .sidebar-card { display: none; }
    .app.sidebar-collapsed .sidebar { padding-inline: 8px; }
    .app.sidebar-collapsed .sidebar-head { justify-content: center; }
    .app.sidebar-collapsed .brand { flex: 0; padding: 0; background: transparent; border: 0; }
    .app.sidebar-collapsed .nav-link { justify-content: center; padding: 6px; overflow: visible; }
    @media (max-width: 1180px) { .hero, .dashboard-grid { grid-template-columns: 1fr; } .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (max-width: 1024px) {
      .sidebar { width: min(76vw, 270px); transform: translate3d(-110%,0,0); box-shadow:none; background: var(--panel); backdrop-filter:none; }
      .sidebar.show { transform: translate3d(0,0,0); }
      .main { margin-left:0; width:100%; }
      .topbar { grid-template-columns: 1fr auto; align-items:start; }
      .topbar-left { grid-column:1 / -1; justify-content:space-between; }
      .topbar-center { grid-column:1 / 2; grid-row:2; justify-content:flex-start; }
      .search { max-width:190px; min-width:0; }
      .topbar-right { grid-column:2 / 3; grid-row:2; display:grid; grid-template-columns:auto auto auto auto; gap:6px; }
      .menu-btn { display:grid; }
    }
    @media (max-width: 768px) {
      .topbar-center, .topbar-right { display:none; }
      body { font-size:12.5px; }
      .main { padding:12px; }
      .page-title h2 { font-size:1.14rem; }
      .page-title p { font-size:.72rem; }
      .hero-card, .card { padding:14px; }
      .hero h3 { font-size:1.18rem; }
      .hero, .dashboard-grid { grid-template-columns:1fr; }
      .hero-stats, .stats-grid { grid-template-columns:repeat(2, minmax(0, 1fr)); }
      .chart-wrap { height:280px; min-height:280px; }
      .analytics-card { min-height:0; }
      .property-card { grid-template-columns:1fr; }
      .property-side, .list-side { text-align:left; }
      .list-row { flex-direction:column; align-items:flex-start; }
      .table-shell table { min-width:560px; }
    }
    @media (max-width: 560px) {
      .hero-stats, .stats-grid { grid-template-columns:repeat(2, minmax(0, 1fr)); }
      .chart-wrap { height:260px; min-height:260px; margin-top:12px; }
      .filter-row > * { flex-basis:100%; }
      .table-shell table { min-width:520px; }
    }
  </style>
</head>
<%
  const fullName = (currentUser.fullName || `${currentUser.firstName || ''} ${currentUser.lastName || ''}`.trim() || 'Classic User').trim();
  const firstName = currentUser.firstName || fullName.split(' ')[0] || 'there';
  const initial = (fullName.charAt(0) || 'C').toUpperCase();
  const roleLabel = (currentUser.role || 'member').replace(/-/g, ' ');
  const fmtNum = (value) => Number(value || 0).toLocaleString();
  const fmtDate = (value) => {
    if (!value) return '-';
    const d = new Date(value);
    return Number.isNaN(d.getTime()) ? '-' : d.toLocaleDateString();
  };
  const fmtDateTime = (value) => {
    if (!value) return '-';
    const d = new Date(value);
    return Number.isNaN(d.getTime()) ? '-' : `${d.toLocaleDateString()} ${d.toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' })}`;
  };
  const fmtMoney = (amount, currency = 'USD', unit = '') => `${currency} ${fmtNum(amount)}${unit ? ` / ${unit}` : ''}`;
  const percent = (value) => Math.max(0, Math.min(100, Number(value || 0)));
  const listingStatusUI = (status) => status === 'published' ? 'occupied' : status === 'pending' ? 'pending' : 'vacant';
  const listingStatusLabel = (status) => status === 'published' ? 'Published' : status === 'pending' ? 'Pending' : status === 'draft' ? 'Draft' : status === 'archived' ? 'Archived' : status || 'Unknown';
  const sampleImage = 'https://images.unsplash.com/photo-1460317442991-0ec209397118?auto=format&fit=crop&w=900&q=80';
  const latestListings = Array.isArray(recentListings) ? recentListings.slice(0, 3) : [];
  const latestInquiries = Array.isArray(recentInquiries) ? recentInquiries.slice(0, 3) : [];
  const latestReviews = Array.isArray(recentReviews) ? recentReviews.slice(0, 2) : [];
  const latestReports = Array.isArray(recentReports) ? recentReports.slice(0, 2) : [];
  const latestLogs = Array.isArray(recentLogs) ? recentLogs.slice(0, 2) : [];
  const totalAlerts = Number(stats.newInquiries || 0) + Number(stats.openReports || 0);
  const listingSeries = (Array.isArray(listingTimeline) ? listingTimeline : []).map((item) => new Date(item.createdAt)).filter((d) => !Number.isNaN(d.getTime()));
  const inquirySeries = (Array.isArray(inquiryTimeline) ? inquiryTimeline : []).map((item) => new Date(item.createdAt)).filter((d) => !Number.isNaN(d.getTime()));
  const last7Labels = Array.from({ length: 7 }, (_, idx) => {
    const d = new Date(); d.setDate(d.getDate() - (6 - idx));
    return d.toLocaleDateString([], { weekday: 'short' });
  });
  const tallySeries = (dates) => Array.from({ length: 7 }, (_, idx) => {
    const day = new Date(); day.setHours(0,0,0,0); day.setDate(day.getDate() - (6 - idx));
    const next = new Date(day); next.setDate(next.getDate() + 1);
    return dates.filter((d) => d >= day && d < next).length;
  });
  const listingPoints = tallySeries(listingSeries);
  const inquiryPoints = tallySeries(inquirySeries);
  const roleHomePath = ['/admin','/super-admin','/agent','/user'].includes(`/${currentUser.role}`) ? `/${currentUser.role}` : '/dashboard';
%>
<body>
  <div class="sidebar-tooltip" id="sidebarTooltip"></div>
  <div class="app" id="appShell">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-head">
        <div class="brand">
          <div class="brand-logo">CR</div>
          <div class="brand-text">
            <h1>Classic Rentals</h1>
            <p><%= roleLabel %> workspace</p>
          </div>
        </div>
        <button class="collapse-btn" id="collapseBtn" aria-label="Toggle sidebar">&lt;</button>
      </div>

      <div class="nav-group">
        <div class="nav-title">Main</div>
        <a class="nav-link active" href="/dashboard" data-label="Dashboard"><span class="nav-icon">⌂</span><span class="nav-label">Dashboard</span></a>
        <a class="nav-link" href="/dashboard/analytics" data-label="Analytics"><span class="nav-icon">◔</span><span class="nav-label">Analytics</span></a>
        <a class="nav-link" href="/dashboard/manage-listings" data-label="Listings"><span class="nav-icon">▣</span><span class="nav-label">Listings</span></a>
        <a class="nav-link" href="/dashboard/inquiries" data-label="Inquiries"><span class="nav-icon">✉</span><span class="nav-label">Inquiries</span></a>
