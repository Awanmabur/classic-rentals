<%- include('../../partials/head', { title }) %>
<section class="authStandalone authStandalone--simple">
  <div class="authStandalone__shell">
    <div class="authBrandPanel panel">
      <a class="authBrandMark" href="/">CR</a>
      <span class="authEyebrow">Classic Rentals account</span>
      <h1>Set a new password</h1>
      <p>Use a strong password to keep your workspace secure.</p>
    </div>
    <div class="panel authCard authCard--modern">
      <div class="authCardHead">
        <span class="authMiniBadge">Security</span>
        <h2>Reset password</h2>
        <p>Complete the form below to finish resetting your password.</p>
      </div>
      <% if (!valid) { %>
        <div class="authNotice authNotice--danger">This reset link is invalid or expired.</div>
        <div class="authActions authActions--stack"><a class="btn" href="/auth/forgot-password">Request a new link</a></div>
      <% } else if (reset) { %>
        <div class="authNotice authNotice--success">Your password has been updated successfully.</div>
        <div class="authActions authActions--stack"><a class="btn" href="/auth/login">Back to login</a></div>
      <% } else { %>
        <form action="/auth/reset-password/<%= token %>" method="post">
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          <div class="authFormGrid authFormGrid--single">
            <label class="fieldBlock">New password
              <div class="passwordField">
                <input class="input" id="resetPassword" type="password" name="password" placeholder="New password" required />
                <button class="passwordToggle" type="button" data-password-toggle="resetPassword" aria-label="Show password">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"/></svg>
                </button>
              </div>
              <% if (formErrors?.password) { %><small class="fieldError"><%= formErrors.password %></small><% } %>
            </label>
            <label class="fieldBlock">Confirm password
              <div class="passwordField">
                <input class="input" id="resetConfirmPassword" type="password" name="confirmPassword" placeholder="Confirm password" required />
                <button class="passwordToggle" type="button" data-password-toggle="resetConfirmPassword" aria-label="Show password">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"/></svg>
                </button>
              </div>
              <% if (formErrors?.confirmPassword) { %><small class="fieldError"><%= formErrors.confirmPassword %></small><% } %>
            </label>
          </div>
          <div class="authActions authActions--stack">
            <button class="btn" type="submit">Update password</button>
          </div>
        </form>
      <% } %>
    </div>
  </div>
</section>
<script>
  document.querySelectorAll('[data-password-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const input = document.getElementById(btn.dataset.passwordToggle);
      if (!input) return;
      const visible = input.type === 'text';
      input.type = visible ? 'password' : 'text';
      btn.setAttribute('aria-label', visible ? 'Show password' : 'Hide password');
      btn.innerHTML = visible
        ? '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"/></svg>'
        : '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 3l18 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M10.6 10.7a2 2 0 0 0 2.7 2.7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M9.9 5.1A11.5 11.5 0 0 1 12 5c6.5 0 10 7 10 7a18.8 18.8 0 0 1-3.3 3.9M6.6 6.7C4 8.3 2 12 2 12s3.5 7 10 7c1.8 0 3.3-.4 4.6-1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>';
    });
  });
</script>
</body>
</html>
