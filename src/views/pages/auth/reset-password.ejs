<%- include('../../partials/head', { title }) %>
<%- include('../../partials/nav') %>
<%- include('../../partials/toast') %>
<section class="authWrap">
  <div class="panel authCard">
    <h1 style="margin-top:0">Reset password</h1>
    <% if (!valid && !reset) { %>
      <p style="color:#fca5a5">This reset link is invalid or expired.</p>
      <a class="btn" href="/auth/forgot-password">Request a new link</a>
    <% } else { %>
      <form action="/auth/reset-password/<%= token %>" method="post" style="display:grid;gap:12px">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <label>New password<input class="input" type="password" name="password" required> <% if (formErrors?.password) { %><small style="color:#fca5a5"><%= formErrors.password %></small><% } %></label>
        <label>Confirm password<input class="input" type="password" name="confirmPassword" required> <% if (formErrors?.confirmPassword) { %><small style="color:#fca5a5"><%= formErrors.confirmPassword %></small><% } %></label>
        <button class="btn" type="submit">Update password</button>
      </form>
    <% } %>
  </div>
</section>
<%- include('../../partials/footer') %>
