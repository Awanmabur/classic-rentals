<%- include('../../partials/head', { title }) %>
<section class="authStandalone authStandalone--simple">
  <div class="authStandalone__shell">
    <div class="authBrandPanel panel">
      <a class="authBrandMark" href="/">CR</a>
      <span class="authEyebrow">Classic Rentals account</span>
      <h1>Reset access</h1>
      <p>Enter your email and we will send a secure link to help you reset your password.</p>
    </div>
    <form class="panel authCard authCard--modern" action="/auth/forgot-password" method="post">
      <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <div class="authCardHead">
        <span class="authMiniBadge">Password help</span>
        <h2>Forgot password</h2>
        <p>We will email a reset link if your account exists.</p>
      </div>
      <% if (sent) { %><div class="authNotice authNotice--success">If the email exists, a reset link has been sent.</div><% } %>
      <label class="fieldBlock">Email address
        <input class="input" type="email" name="email" value="<%= old?.email || '' %>" placeholder="Email address" required />
        <% if (formErrors?.email) { %><small class="fieldError"><%= formErrors.email %></small><% } %>
      </label>
      <div class="authActions authActions--stack">
        <button class="btn" type="submit">Send reset link</button>
      </div>
      <div class="authAltLine">
        <a href="/auth/login">Back to login</a>
      </div>
    </form>
  </div>
</section>
</body>
</html>
