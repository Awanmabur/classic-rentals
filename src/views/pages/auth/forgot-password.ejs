<%- include('../../partials/head', { title }) %>
<%- include('../../partials/nav') %>
<%- include('../../partials/toast') %>
<section class="authWrap">
  <form class="panel authCard" action="/auth/forgot-password" method="post">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <h1 style="margin-top:0">Forgot password</h1>
    <p style="color:var(--muted)">Enter your email and we will send a reset link if an account exists.</p>
    <label>Email
      <input class="input" type="email" name="email" value="<%= old?.email || '' %>" placeholder="Email address" required>
      <% if (formErrors?.email) { %><small style="color:#fca5a5"><%= formErrors.email %></small><% } %>
    </label>
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:14px">
      <button class="btn" type="submit">Send reset link</button>
      <a class="btn alt" href="/auth/login">Back to login</a>
    </div>
  </form>
</section>
<%- include('../../partials/footer') %>
