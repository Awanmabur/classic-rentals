<%- include('../../partials/head', { title }) %>
<%- include('../../partials/nav') %>
<%- include('../../partials/toast') %>
<section class="authWrap">
  <form class="panel authCard" id="registerForm" action="/auth/register" method="post">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <h1 style="margin-top:0">Create your account</h1>
    <p style="color:var(--muted)">Create an account to save favorites, send inquiries and manage listings.</p>
    <div style="display:grid;gap:12px">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <label>First name<input class="input" type="text" name="firstName" value="<%= old?.firstName || '' %>" placeholder="First name" required /> <% if (formErrors?.firstName) { %><small style="color:#fca5a5"><%= formErrors.firstName %></small><% } %></label>
        <label>Last name<input class="input" type="text" name="lastName" value="<%= old?.lastName || '' %>" placeholder="Last name" required /> <% if (formErrors?.lastName) { %><small style="color:#fca5a5"><%= formErrors.lastName %></small><% } %></label>
      </div>
      <label>Email<input class="input" type="email" name="email" value="<%= old?.email || '' %>" placeholder="Email address" required /> <% if (formErrors?.email) { %><small style="color:#fca5a5"><%= formErrors.email %></small><% } %></label>
      <label>Phone<input class="input" type="text" name="phone" value="<%= old?.phone || '' %>" placeholder="Phone number" /></label>
      <label>Password<input class="input" type="password" name="password" placeholder="Password" required /> <% if (formErrors?.password) { %><small style="color:#fca5a5"><%= formErrors.password %></small><% } %></label>
      <label>Confirm password<input class="input" type="password" name="confirmPassword" placeholder="Confirm password" required /> <% if (formErrors?.confirmPassword) { %><small style="color:#fca5a5"><%= formErrors.confirmPassword %></small><% } %></label>
      <button class="btn" type="submit">Create account</button>
      <a class="tinyBtn" href="/auth/login">Already have an account? Login</a>
    </div>
  </form>
</section>
<%- include('../../partials/footer') %>
