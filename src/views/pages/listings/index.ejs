<%- include('../../partials/head', { title }) %>
<%- include('../../partials/nav') %>
<section class="section">
  <div class="wrap panel listingIndexTop">
    <div>
      <h1 style="margin:0">Browse listings</h1>
      <p class="subtle">Explore published inventory across cars, homes, land and commercial spaces.</p>
    </div>
    <form action="/listings" method="get" class="filterGrid inlineFilters">
      <input class="input" type="text" name="q" placeholder="Keyword">
      <select name="category">
        <option value="">All categories</option>
        <option value="house">House</option>
        <option value="apartment">Apartment</option>
        <option value="land">Land</option>
        <option value="car">Car</option>
        <option value="shop">Shop</option>
        <option value="office">Office</option>
        <option value="warehouse">Warehouse</option>
        <option value="shortstay">Short-stay</option>
      </select>
      <button class="btn" type="submit">Filter</button>
    </form>
  </div>
</section>
<section class="section compactTop">
  <div class="wrap grid">
    <% listings.forEach(listing => { %>
      <%- include('../../partials/listing-card', { listing, favoriteIds, currentUser }) %>
    <% }) %>
  </div>
</section>
<script>
window.__HOME_LISTINGS__ = <%- JSON.stringify(listings.slice(0, 24)) %>;
window.__IS_AUTHENTICATED__ = <%- JSON.stringify(Boolean(currentUser)) %>;
</script>
<%- include('../../partials/footer') %>
