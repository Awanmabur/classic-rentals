.showMain{overflow:hidden}.showMedia{padding:12px}.showMedia img{width:100%;aspect-ratio:16/10;object-fit:cover;border-radius:22px}.showThumbs{display:grid;grid-template-columns:repeat(auto-fill,minmax(84px,1fr));gap:10px;padding:0 12px 12px}.showThumbs button{padding:0;border:0;background:transparent;cursor:pointer}.showThumbs img{width:100%;height:74px;object-fit:cover;border-radius:16px;border:1px solid transparent;transition:.2s var(--ease)}.showThumbs button.active img,.showThumbs button:hover img{border-color:color-mix(in oklab,var(--primary) 70%, white 8%);transform:translateY(-2px)}
.showBody{padding:6px 18px 20px}.showBadgeRow{display:flex;flex-wrap:wrap;gap:8px;margin:0 0 10px}.showBadge{display:inline-flex;align-items:center;gap:7px;padding:8px 12px;border-radius:999px;border:1px solid var(--line);background:rgba(255,255,255,.05);font-size:12px;font-weight:700}.showBadge.ok{color:#f7d58a}.showBadge.feat{color:#f3c56d}.showTitle{font-size:clamp(1.6rem,2vw,2.25rem);line-height:1.1;margin:0 0 8px}.showLocation{color:var(--muted);margin:0 0 10px;font-size:14px}.showPrice{display:flex;align-items:end;gap:10px;flex-wrap:wrap;margin:0 0 14px}.showPrice strong{font-size:1.55rem;line-height:1}.showPrice span{color:var(--muted);font-size:14px;padding-bottom:2px}.showMeta{display:flex;flex-wrap:wrap;gap:8px;margin:0 0 18px}.showMeta span,.showAmenity{display:inline-flex;align-items:center;padding:8px 12px;border-radius:999px;border:1px solid var(--line);background:rgba(255,255,255,.04);font-size:13px}.showDesc{font-size:14px;line-height:1.8;color:var(--text);margin:0 0 18px}.showSubhead{font-size:1rem;margin:0 0 12px}.showAmenities{display:flex;flex-wrap:wrap;gap:8px}
.showAside{padding:18px;position:sticky;top:110px}.ownerCard{display:flex;align-items:center;gap:12px;margin-bottom:14px}.ownerAvatar{width:52px;height:52px;border-radius:18px;display:grid;place-items:center;background:linear-gradient(180deg,var(--primary),var(--primary2));color:white;font-weight:800;box-shadow:0 12px 30px rgba(205, 119, 0,.35)}.ownerMeta strong{display:block;font-size:15px}.ownerMeta span{display:block;font-size:13px;color:var(--muted);margin-top:3px}.contactRows{display:grid;gap:10px;margin:14px 0 16px}.contactRow{display:flex;flex-direction:column;gap:3px;padding:12px 14px;border-radius:16px;border:1px solid var(--line);background:rgba(255,255,255,.04)}.contactRow small{font-size:11px;letter-spacing:.04em;color:var(--muted);text-transform:uppercase}.contactRow b{font-size:14px;word-break:break-word}.showForm{display:grid;gap:10px}.showForm .input{width:100%;border:1px solid var(--line);background:var(--input-bg);color:var(--text);border-radius:16px;padding:13px 14px;outline:none}.showForm textarea.input{min-height:128px;resize:vertical}.showForm .input:focus{border-color:color-mix(in oklab,var(--primary) 68%, white 10%);box-shadow:0 0 0 4px rgba(205, 119, 0,.12)}.showAside .btn{width:100%;justify-content:center}.showActions{display:grid;gap:10px;margin-top:10px}.crumbs{display:flex;flex-wrap:wrap;gap:8px;font-size:12px;color:var(--muted);margin-bottom:12px}.crumbs a:hover{text-decoration:underline}.showNotice{padding:12px 14px;border-radius:16px;background:rgba(205, 119, 0,.10);border:1px solid rgba(205, 119, 0,.22);font-size:13px;color:var(--muted);margin-top:14px}
