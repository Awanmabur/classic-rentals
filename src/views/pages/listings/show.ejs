<section class="showWrap">
  <div class="wrap">
    <div class="showShell">
      <article class="showMain">
        <div class="showMedia">
          <img id="listingMainImage" src="<%= primaryImage %>" alt="<%= listing.title %>">
        </div>
        <% if (images.length > 1) { %>
        <div class="showThumbs">
          <% images.forEach((img, idx) => { %>
            <button type="button" class="<%= idx === 0 ? 'active' : '' %>" data-image-src="<%= img.url %>">
              <img src="<%= img.url %>" alt="<%= listing.title %> preview <%= idx + 1 %>">
            </button>
          <% }) %>
        </div>
        <% } %>
        <div class="showBody">
          <div class="showBadgeRow">
            <% if (listing.verified) { %><span class="showBadge ok">Verified</span><% } %>
            <% if (listing.featured) { %><span class="showBadge feat">Featured</span><% } %>
            <% if (listing.category) { %><span class="showBadge"><%= listing.category %></span><% } %>
            <% if (listing.purpose) { %><span class="showBadge"><%= listing.purpose %></span><% } %>
          </div>
          <h1 class="showTitle"><%= listing.title %></h1>
          <p class="showLocation"><%= [listing.location?.area, listing.location?.city, listing.location?.country].filter(Boolean).join(', ') %></p>
          <div class="showPrice"><strong><%= priceCurrency %> <%= priceAmount %></strong><span><%= priceUnit %></span></div>
          <div class="showMeta">
            <% if (listing.specs?.bedrooms) { %><span><%= listing.specs.bedrooms %> bedrooms</span><% } %>
            <% if (listing.specs?.bathrooms) { %><span><%= listing.specs.bathrooms %> bathrooms</span><% } %>
            <% if (listing.specs?.sizeSqm) { %><span><%= listing.specs.sizeSqm %> sqm</span><% } %>
            <% if (listing.specs?.year) { %><span>Year <%= listing.specs.year %></span><% } %>
            <% if (listing.specs?.mileage) { %><span><%= listing.specs.mileage %> km</span><% } %>
            <% if (listing.location?.city) { %><span><%= listing.location.city %></span><% } %>
          </div>
          <p class="showDesc"><%= listing.description %></p>
          <div class="converterBox" data-converter data-amount="<%= Number(listing.price?.amount || 0) %>" data-currency="<%= priceCurrency %>">
            <div class="converterHead">
              <div>
                <strong>Currency converter</strong>
                <span class="converterAmount"><%= priceCurrency %> <%= priceAmount %> <%= priceUnit %></span>
              </div>
              <select class="input" data-converter-target aria-label="Convert price to">
                <option value="SSP">SSP</option>
                <option value="UGX">UGX</option>
                <option value="KES">KES</option>
                <option value="EUR">EUR</option>
                <option value="GBP">GBP</option>
              </select>
            </div>
            <div class="converterResult" data-converter-output>Loading live rate...</div>
            <div class="converterSource" data-converter-source>Using live exchange rates when available.</div>
          </div>
          <div class="intelGrid">
            <div class="intelCard"><small>Security rating</small><strong><%= intel.securityRating && intel.securityRating !== 'unknown' ? intel.securityRating : 'Not rated yet' %></strong></div>
            <div class="intelCard"><small>Traffic jam indicator</small><strong><%= intel.trafficIndicator && intel.trafficIndicator !== 'unknown' ? intel.trafficIndicator : 'Not reported yet' %></strong></div>
            <div class="intelCard"><small>Map location</small><strong><%= hasPaidSurveyMap ? 'Survey fee paid' : 'Hidden until survey fee is paid' %></strong></div>
            <div class="intelCard"><small>Room availability timer</small><strong class="countdownValue" data-vacate-at="<%= vacateIso %>"><%= vacateIso ? 'Calculating...' : 'No leaving date set' %></strong></div>
            <div class="intelCard"><small>Listing tier</small><strong><%= monet.tier ? monet.tier.charAt(0).toUpperCase() + monet.tier.slice(1) : 'Free' %></strong></div>
          </div>
          <% if ((listing.videos || []).length) { %>
            <div class="roomVideo">
              <h2 class="showSubhead">Room appearance video</h2>
              <video src="<%= listing.videos[0].url %>" controls playsinline></video>
            </div>
          <% } %>
          <div class="mapGate">
            <% if (hasPaidSurveyMap) { %>
              <h2 class="showSubhead">Apartment map location</h2>
              <iframe class="mapFrame" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="https://www.google.com/maps?q=<%= encodeURIComponent(`${listing.location.latitude},${listing.location.longitude}`) %>&output=embed"></iframe>
            <% } else { %>
              <div class="showNotice">Exact apartment map location is shown after the survey fee is paid.</div>
            <% } %>
          </div>
          <% if (listing.amenities && listing.amenities.length) { %>
            <h2 class="showSubhead">Amenities</h2>
            <div class="showAmenities">
              <% listing.amenities.forEach(item => { %><span class="showAmenity"><%= item %></span><% }) %>
            </div>
          <% } %>
        </div>
      </article>

      <aside class="showAside">
        <div class="ownerCard">
          <div class="ownerAvatar"><%= (ownerName || 'Owner').split(' ').map(n => n[0]).slice(0,2).join('').toUpperCase() %></div>
          <div class="ownerMeta">
            <strong><%= ownerName %></strong>
            <span>Responds to inquiries from this page</span>
          </div>
        </div>

        <div class="contactRows">
          <div class="contactRow"><small>Phone</small><b><%= ownerPhone %></b></div>
          <div class="contactRow"><small>Email</small><b><%= ownerEmail %></b></div>
          <div class="contactRow"><small>Listing type</small><b><%= [listing.category, listing.purpose].filter(Boolean).join(' • ') || 'Rental listing' %></b></div>
        </div>

        <form id="inquiryForm" class="showForm">
          <input type="hidden" name="type" value="general">
          <input class="input" name="name" placeholder="Your name" value="<%= currentUser ? [currentUser.firstName, currentUser.lastName].filter(Boolean).join(' ') : '' %>" />
          <input class="input" name="email" placeholder="Email" value="<%= currentUser ? currentUser.email : '' %>" />
          <input class="input" name="phone" placeholder="Phone" value="<%= currentUser ? (currentUser.phone || '') : '' %>" />
          <textarea class="input" name="message" placeholder="I am interested in this listing. Please share more details."></textarea>
          <button class="btn primary" type="submit">Send inquiry</button>
        </form>

        <% if (monet.viewingFeeEnabled || monet.reservationFeeEnabled) { %>
          <form id="bookingForm" class="showForm" style="margin-top:14px">
            <h3 style="margin:0 0 10px">Book viewing / reserve</h3>
            <select class="input" name="type">
              <option value="viewing" <%= monet.viewingFeeEnabled ? '' : 'disabled' %>>Viewing request<%= monet.viewingFeeEnabled ? ` • ${monet.viewingFeeCurrency || priceCurrency} ${Number(monet.viewingFeeAmount || 0).toLocaleString()}` : '' %></option>
              <option value="reservation" <%= monet.reservationFeeEnabled ? '' : 'disabled' %>>Reservation request<%= monet.reservationFeeEnabled ? ` • ${monet.reservationFeeCurrency || priceCurrency} ${Number(monet.reservationFeeAmount || 0).toLocaleString()}` : '' %></option>
            </select>
            <input class="input" name="name" placeholder="Your name" value="<%= currentUser ? [currentUser.firstName, currentUser.lastName].filter(Boolean).join(' ') : '' %>" />
            <input class="input" name="email" placeholder="Email" value="<%= currentUser ? currentUser.email : '' %>" />
            <input class="input" name="phone" placeholder="Phone" value="<%= currentUser ? (currentUser.phone || '') : '' %>" />
            <input type="hidden" name="provider" value="pesapal" />
            <div class="noteCard" style="margin:0 0 4px">Paid requests are sent to secure checkout before they reach the agent as paid.</div>
            <textarea class="input" name="message" placeholder="I want to view or reserve this listing."></textarea>
            <button class="btn primary" type="submit">Send booking request</button>
          </form>
        <% } %>

        <div class="showActions">
          <button class="btn" type="button" data-favorite-id="<%= listing._id %>">Save listing</button>
          <a class="btn" href="/listings">Back to listings</a>
        </div>

      </aside>
    </div>
  </div>
</section>
