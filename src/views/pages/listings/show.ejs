            letter-spacing: -.2px;
            font-size: 14px
        }

        .per {
            color: var(--muted);
            font-weight: 800;
            font-size: 12px
        }

        .tinyBtn {
            padding: 8px 10px;
            border-radius: 14px;
            border: 1px solid var(--line);
