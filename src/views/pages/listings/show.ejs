        /* Footer */

        .contactSection { padding: 10px 0 34px; }
        .contactShell { display:grid; grid-template-columns: minmax(0,.95fr) minmax(0,1.05fr); gap:18px; align-items:stretch; }
        .contactInfoCard, .contactFormCard { border-radius: 26px; border:1px solid var(--line); background: var(--card); box-shadow: var(--shadow); padding: 22px; }
        .contactBadge { display:inline-flex; align-items:center; gap:8px; padding:8px 12px; border-radius:999px; background: rgba(205, 119, 0,.14); color:#f3c56d; font-size:12px; font-weight:900; letter-spacing:.04em; text-transform:uppercase; }
        :root[data-theme="light"] .contactBadge { color: var(--primary); }
        .contactTitle { margin: 10px 0 8px; font-size: clamp(1.24rem, 2vw, 1.7rem); line-height:1.12; }
        .contactLead { margin:0; font-size: .84rem; line-height: 1.65; color: var(--muted); max-width: 52ch; }
        .contactQuickGrid { display:grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap:12px; margin-top:18px; }
        .contactQuickItem { padding:12px 13px; border-radius:18px; border:1px solid var(--line); background: rgba(255,255,255,.04); display:grid; gap:3px; }
        .contactQuickItem strong { font-size: .68rem; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); }
        .contactQuickItem span, .contactQuickItem a { color: var(--text); font-size: .82rem; font-weight: 700; word-break: break-word; }
        .contactMiniNote { margin-top: 16px; padding: 12px 14px; border-radius: 18px; background: rgba(205, 119, 0,.10); border:1px solid rgba(205, 119, 0,.18); color: var(--muted); font-size: .8rem; line-height: 1.6; }
        .contactFormCard { display:grid; gap:14px; }
        .contactFormTop h3 { margin:0 0 6px; font-size:1rem; }
        .contactFormTop p { margin:0; color: var(--muted); font-size:.82rem; line-height:1.6; }
        .contactFormGrid { display:grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap:12px; }
        .contactField { display:grid; gap:7px; }
        .contactField label { font-size:.78rem; font-weight:700; color: var(--text); }
        .contactField input, .contactField textarea { width:100%; border-radius:16px; border:1px solid var(--line); background: var(--input-bg); color: var(--text); padding: 11px 13px; font-size:.84rem; }
        .contactField textarea { min-height: 136px; resize: vertical; }
        .contactField--wide { grid-column: 1 / -1; }
        .contactActions { display:flex; justify-content:flex-end; gap:12px; flex-wrap:wrap; }
        .contactActions .btn { min-width: 180px; }
        @media (max-width: 860px) { .contactShell { grid-template-columns:1fr; } .contactFormGrid, .contactQuickGrid { grid-template-columns:1fr; } }


        .fabStack {
            position: fixed;
            right: 18px;
            bottom: 18px;
            z-index: 140;
            display: grid;
            gap: 12px;
        }
        .fabItem {
            position: relative;
            display: flex;
            justify-content: flex-end;
        }
        .fabLabel {
            position: absolute;
            right: calc(100% + 10px);
            top: 50%;
            transform: translateY(-50%) translateX(8px);
            padding: 8px 11px;
            border-radius: 999px;
            background: rgba(10, 16, 31, .92);
            border: 1px solid rgba(255,255,255,.12);
            color: #fff;
            white-space: nowrap;
            font-size: 11px;
            font-weight: 800;
            opacity: 0;
            visibility: hidden;
            transition: opacity .22s var(--ease), transform .22s var(--ease), visibility .22s var(--ease);
            pointer-events: none;
            box-shadow: 0 16px 34px rgba(0,0,0,.24);
        }
        :root[data-theme="light"] .fabLabel {
            background: rgba(255,255,255,.98);
            color: var(--text);
            border-color: rgba(15,23,42,.08);
        }
        .fabItem:hover .fabLabel,
        .fabItem:focus-within .fabLabel {
            opacity: 1;
            visibility: visible;
            transform: translateY(-50%) translateX(0);
        }
        .fabBtn {
            width: 46px;
            height: 46px;
            border-radius: 999px;
            display: grid;
            place-items: center;
            border: 1px solid var(--line);
            background: rgba(10, 16, 31, .9);
            color: #fff;
            box-shadow: 0 18px 34px rgba(0,0,0,.22);
            backdrop-filter:none;
            -webkit-backdrop-filter:none
            transition: transform .18s var(--ease), background .18s var(--ease), opacity .18s var(--ease), box-shadow .18s var(--ease);
        }
        .fabBtn:hover { transform: translateY(-2px); }
.listingCard { cursor: pointer; transition: transform .26s var(--ease), box-shadow .26s var(--ease), border-color .26s var(--ease); }
        .listingCard:hover { transform: translateY(-6px); box-shadow: 0 26px 54px rgba(0,0,0,.22); border-color: rgba(205,119,0,.28); }
        .listingCard .thumb img { transition: transform .42s var(--ease); }
        .listingCard:hover .thumb img { transform: scale(1.04); }
        .listingCard .tinyBtn { transition: transform .18s var(--ease), background .18s var(--ease), color .18s var(--ease); }
        .listingCard:hover .tinyBtn { transform: translateX(2px); }
        .fabBtn:hover { transform: translateY(-3px) scale(1.04); box-shadow: 0 22px 38px rgba(0,0,0,.26); }
        .fabBtn.topBtn {
            background: #cd7700;
            color: #fff;
            border-color: rgba(205, 119, 0, .45);
            box-shadow: 0 18px 36px rgba(205, 119, 0, .24);
            opacity: 0;
            pointer-events: none;
            transform: translateY(12px) scale(.9);
        }
        .fabBtn.topBtn.show {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0) scale(1);
        }
        .fabBtn .ico { width: 18px; height: 18px; }
        :root[data-theme="light"] .fabBtn {
            background: rgba(255,255,255,.96);
            color: var(--text);
            border-color: rgba(15,23,42,.08);
        }
        :root[data-theme="light"] .fabBtn.topBtn { background: #cd7700; color: #fff; border-color: rgba(205, 119, 0, .45); box-shadow: 0 18px 36px rgba(205, 119, 0, .24); }
        [data-smoove] { opacity: 0; transform: translateY(18px); transition: opacity .55s var(--ease), transform .55s var(--ease); }
        [data-smoove].is-visible { opacity: 1; transform: translateY(0); }
        [data-smoove].is-visible { opacity: 1; transform: translateY(0); filter: blur(0); }
        [data-smoove="left"] { transform: translateX(-30px); }
        [data-smoove="right"] { transform: translateX(30px); }
        [data-smoove="top"] { transform: translateY(-30px); }
        [data-smoove="bottom"] { transform: translateY(30px); }
        [data-smoove="zoom"] { transform: translateY(18px) scale(.94); }
        [data-smoove="zoom-out"] { transform: translateY(10px) scale(1.08); }
        [data-smoove="spin-left"] { transform: translateX(-24px) rotate(-4deg) scale(.96); }
        [data-smoove="spin-right"] { transform: translateX(24px) rotate(4deg) scale(.96); }
        [data-smoove="left"].is-visible,
        [data-smoove="right"].is-visible,
        [data-smoove="top"].is-visible,
        [data-smoove="bottom"].is-visible,
        [data-smoove="zoom"].is-visible,
        [data-smoove="zoom-out"].is-visible,
        [data-smoove="spin-left"].is-visible,
        [data-smoove="spin-right"].is-visible { transform: translate(0, 0) scale(1) rotate(0deg); }
        @media (max-width: 640px) {
            .fabStack { right: 12px; bottom: 12px; gap: 10px; }
            .fabBtn { width: 42px; height: 42px; }
            .fabLabel { font-size: 10px; padding: 7px 9px; }
        }

        footer {
            padding: 24px 0 34px;
            border-top: 1px solid var(--line);
            margin-top: 18px;
            opacity: 1 !important;
            visibility: visible !important;
        }

        #footer,
        #footer .footerShell,
        #footer .footTop,
        #footer .footBox,
        #footer .fine {
            opacity: 1 !important;
            visibility: visible !important;
            transform: none !important;
            filter: none !important;
        }

        .footerShell {
            border: 1px solid var(--line);
            border-radius: 28px;
            background: rgba(255, 255, 255, .05);
            backdrop-filter: blur(var(--blur));
            -webkit-backdrop-filter: blur(var(--blur));
            padding: 18px;
        }

        :root[data-theme="light"] .footerShell {
            background: rgba(255, 255, 255, .78)
        }

        .footTop {
            display: grid;
            grid-template-columns: minmax(0, 1.22fr) repeat(3, minmax(0, 1fr));
            gap: 18px;
            column-gap: 24px;
            margin-bottom: 16px;
            align-items: start;
        }

        @media (max-width:980px) {
            .footTop {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width:520px) {
            .footTop {
                grid-template-columns: 1fr;
            }
        }

        .footBox {
            min-width: 0;
            padding: 8px 6px;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .footBox:first-child {
            padding-right: 18px;
            margin-right: 8px;
        }

        .footBox h4 {
            margin: 0 0 10px;
            font-size: 14px
        }

        .footBox a {
            display: block;
            padding: 7px 0;
            color: var(--muted);
            font-size: 13px
        }

        .footBox a:hover {
            color: var(--text);
            text-decoration: underline
        }

        .fine {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
