    <!-- HERO: improved slide -->
    <%
const images = listing.images && listing.images.length ? listing.images : [{ url: 'https://images.unsplash.com/photo-1560518883-ce09059eeffa?q=80&w=1400&auto=format&fit=crop' }];
const primaryImageObj = images.find(img => img.isPrimary) || images[0];
const primaryImage = primaryImageObj?.url || 'https://images.unsplash.com/photo-1560518883-ce09059eeffa?q=80&w=1400&auto=format&fit=crop';
const ownerName = listing.owner ? [listing.owner.firstName, listing.owner.lastName].filter(Boolean).join(' ') : 'Owner';
const ownerPhone = listing.owner?.phone || '+256 781 977 217';
const ownerEmail = listing.owner?.email || 'info@classicrentals.example';
const priceCurrency = listing.price?.currency || 'USD';
const priceAmount = Number(listing.price?.amount || 0).toLocaleString();
const priceUnit = listing.price?.unit === 'one-time' ? 'One time' : '/' + (listing.price?.unit || 'month');
const intel = listing.apartmentIntel || {};
const monet = listing.monetization || {};
const hasPaidSurveyMap = Boolean(intel.surveyFeePaid && listing.location?.latitude && listing.location?.longitude);
const vacateIso = intel.expectedVacateAt ? new Date(intel.expectedVacateAt).toISOString() : '';
%>
<style>
