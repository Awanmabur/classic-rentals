            align-items: flex-start;
            gap: 10px;
            margin-bottom: 8px
        }

        .card h3 {
            margin: 0;
            font-size: 15px;
            letter-spacing: -.2px;
            line-height: 1.25;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .fav {
            width: 32px;
            height: 32px;
            border-radius: 12px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .05);
            color: rgba(238, 242, 255, .92);
            display: grid;
            place-items: center;
            cursor: pointer;
            transition: transform .18s var(--ease), background .18s var(--ease), color .18s var(--ease), border-color .18s var(--ease), box-shadow .18s var(--ease);
            flex: 0 0 auto;
            -webkit-tap-highlight-color: transparent;
        }

        :root[data-theme="light"] .fav {
            background: #ffffff;
            color: #334155;
            border-color: rgba(15, 23, 42, .12);
            box-shadow: 0 6px 18px rgba(15, 23, 42, .07);
        }

        .fav svg,
        .iconBtn svg,
        .modalClose svg {
            display: block;
        }

        .fav:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .10)
        }

        :root[data-theme="light"] .fav:hover {
            background: #f8fafc;
            color: #0f172a;
            border-color: rgba(205, 119, 0, .18);
        }

        .fav.active {
            color: #ff5a5f;
            background: rgba(255, 90, 95, .14);
            border-color: rgba(255, 90, 95, .45);
            box-shadow: 0 0 0 4px rgba(255, 90, 95, .12)
        }

        .fav.active svg,
        .iconBtn.active svg,
        .modalClose:hover svg {
            filter: none;
        }

        .fav.active path,
        .iconBtn.active path {
            fill: currentColor;
            stroke: currentColor;
        }

