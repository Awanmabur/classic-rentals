<!doctype html>
<html lang="en" data-theme="dark">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Classic Rentals — Premium Rentals Platform</title>
    <meta name="description"
        content="Classic Rentals: cars, houses, land, shops, offices & short-stays in Juba. Verified listings, fast search, premium experience." />
    <meta name="theme-color" content="#070a14" />
    <meta name="color-scheme" content="dark light" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --bg: #070a14;
            --bg2: #060815;
            --card: rgba(255, 255, 255, .07);
            --card2: rgba(255, 255, 255, .10);
            --line: rgba(255, 255, 255, .12);
            --text: #eef2ff;
            --muted: rgba(238, 242, 255, .72);
            --shadow: 0 28px 90px rgba(0, 0, 0, .55);
            --r: 18px;
            --r2: 24px;

            --primary: #cd7700;
            --primary2: #a86100;
            --ok: #b36800;
            --warn: #9a6b00;
            --accent-soft: rgba(205, 119, 0, .16);
            --input-bg: rgba(255, 255, 255, .06);
            --input-bg-strong: rgba(255, 255, 255, .09);
            --option-bg: #0d1324;
            --option-text: #eef2ff;

            --ease: cubic-bezier(.2, .9, .2, 1);
            --wrap: 1180px;
            --g: 14px;
            --pad: 16px;
            --blur: 16px;

            --scroll-pad: 88px;
        }

        :root[data-theme="light"] {
            --bg: #f7f9fc;
            --bg2: #eef3fb;
            --card: rgba(255, 255, 255, .94);
            --card2: #ffffff;
            --line: rgba(15, 23, 42, .08);
            --text: #0f172a;
            --muted: rgba(15, 23, 42, .64);
            --shadow: 0 18px 48px rgba(15, 23, 42, .12);
            --accent-soft: rgba(205, 119, 0, .08);
            --input-bg: #ffffff;
            --input-bg-strong: #f8fafc;
            --option-bg: #ffffff;
            --option-text: #0f172a;
        }

        * {
            box-sizing: border-box
        }

        html {
            scroll-behavior: smooth;
            scroll-padding-top: var(--scroll-pad)
        }

        body {
            margin: 0;
            font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, "Helvetica Neue", Arial;
            background:
                radial-gradient(1200px 700px at 12% 6%, rgba(205, 119, 0, .30), transparent 60%),
                radial-gradient(1000px 600px at 85% 12%, rgba(179, 104, 0, .16), transparent 55%),
                radial-gradient(900px 600px at 50% 110%, rgba(154, 107, 0, .12), transparent 55%),
                linear-gradient(180deg, var(--bg), var(--bg2));
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        a {
            color: inherit;
            text-decoration: none
        }

        button,
        input,
        select {
            font: inherit
        }

        img {
            max-width: 100%;
            display: block
        }

        input,
        select,
        textarea,
        button {
            accent-color: var(--primary);
        }

        select,
        option,
        optgroup {
            color: var(--option-text);
            background: var(--option-bg);
        }

        select {
            appearance: none;
            -webkit-appearance: none;
            background-image: linear-gradient(45deg, transparent 50%, currentColor 50%), linear-gradient(135deg, currentColor 50%, transparent 50%);
            background-position: calc(100% - 18px) calc(50% - 2px), calc(100% - 12px) calc(50% - 2px);
            background-size: 6px 6px, 6px 6px;
            background-repeat: no-repeat;
            padding-right: 28px !important;
        }

        .wrap {
            max-width: var(--wrap);
            margin: 0 auto;
            padding: 0 16px
        }

        @media (max-width:420px) {
            .wrap {
                padding: 0 12px
            }
        }

        .row {
            display: flex;
            align-items: center
        }

        .muted {
            color: var(--muted)
        }

        /* Topbar */
        .topbar {
            position: sticky;
            top: 0;
            z-index: 110;
            content: "";
            /* backdrop-filter:none;
            -webkit-backdrop-filter:none */
            /* background: transparent; */
            
        }

        :root[data-theme="light"] .topbar {
            background: linear-gradient(180deg, rgba(255, 255, 255, .92), rgba(255, 255, 255, .76));
            border-bottom: 1px solid rgba(15, 23, 42, .06);
        }

        .topbarRow {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 10px 0;
            color: var(--muted);
            font-size: 13px;
            flex-wrap: wrap;
        }

        .chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 10px;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .04);
            white-space: nowrap;
        }

        :root[data-theme="light"] .chip {
            background: rgba(0, 0, 0, .03)
        }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--ok);
            box-shadow: 0 0 0 4px rgba(179, 104, 0, .12)
        }

        .topLinks {
            display: flex;
            gap: 12px;
            align-items: center;
            flex-wrap: wrap
        }

        .link {
            color: var(--text);
            opacity: .9
        }

        .link:hover {
            opacity: 1;
            text-decoration: underline
        }

        @media (max-width:520px) {
            .topLinks {
                display: none
            }
        }

        /* Navbar */
.nav {
    position: sticky;
    top: 44px;
    z-index: 109;
    background: transparent;
    isolation: isolate;
}

.nav::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: -10px;
    bottom: -10px;
    z-index: -1;
    pointer-events: none;

    background: color-mix(in oklab, var(--bg), transparent 90%);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);

    -webkit-mask-image: linear-gradient(
        to bottom,
        transparent 0%,
        #000 16%,
        #000 84%,
        transparent 100%
    );
    mask-image: linear-gradient(
        to bottom,
        transparent 0%,
        #000 16%,
        #000 84%,
        transparent 100%
    );
}

:root[data-theme="light"] .nav::before {
    background: rgba(255, 255, 255, .84);
    border-bottom: 1px solid rgba(15, 23, 42, .06);
}

.navRow {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    position: relative;
    z-index: 1;
}
        @media (max-width:920px) {
            .navRow {
                grid-template-columns: 1fr auto
            }
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 220px
        }

        @media (max-width:920px) {
            .brand {
                min-width: auto
            }
        }

        .logo {
            width: 40px;
            height: 40px;
            border-radius: 14px;
            background:
                radial-gradient(12px 12px at 30% 30%, rgba(255, 255, 255, .9), rgba(255, 255, 255, 0) 60%),
                linear-gradient(135deg, rgba(205, 119, 0, 1), rgba(179, 104, 0, .85));
            box-shadow: 0 12px 30px rgba(0, 0, 0, .35);
            position: relative;
            flex: 0 0 auto;
        }

        .logo:after {
            content: "";
            position: absolute;
            inset: 1px;
            border-radius: 13px;
            border: 1px solid rgba(255, 255, 255, .22)
        }

        .brandTitle {
            display: flex;
            flex-direction: column;
            line-height: 1.1
        }

        .brandTitle b {
            font-size: 15px;
            letter-spacing: .2px
        }

        .brandTitle span {
            font-size: 12px;
            color: var(--muted)
        }

        @media (max-width:420px) {
            .brandTitle span {
                display: none
            }
        }

        .navLinks {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .navLinks a {
            font-size: 14px;
            color: var(--muted);
            padding: 8px 10px;
            border-radius: 12px;
            transition: transform .18s var(--ease), background .18s var(--ease), color .18s var(--ease);
        }

        .navLinks a:hover {
            color: var(--text);
            background: rgba(255, 255, 255, .06);
            transform: translateY(-1px)
        }

        :root[data-theme="light"] .navLinks a:hover {
            background: rgba(0, 0, 0, .04)
        }

        @media (max-width:920px) {
            .navLinks {
                display: none
            }
        }

        .navActions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
            min-width: 220px
        }

        @media (max-width:920px) {
            .navActions {
                min-width: auto
            }
        }

        .iconBtn {
            width: 40px;
            height: 40px;
            border-radius: 14px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .05);
            color: var(--text);
            display: grid;
            place-items: center;
            cursor: pointer;
            transition: transform .18s var(--ease), background .18s var(--ease);
            -webkit-tap-highlight-color: transparent;
        }

        :root[data-theme="light"] .iconBtn {
            background: #ffffff;
            color: #1e293b;
            border-color: rgba(15, 23, 42, .10);
            box-shadow: 0 6px 18px rgba(15, 23, 42, .06);
        }

        .iconBtn:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .08)
        }

        :root[data-theme="light"] .iconBtn:hover {
            background: rgba(0, 0, 0, .05)
        }

        .btn {
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .06);
            color: var(--text);
            padding: 10px 12px;
            border-radius: 14px;
            cursor: pointer;
            transition: transform .18s var(--ease), background .18s var(--ease);
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            font-size: 14px;
            white-space: nowrap;
            -webkit-tap-highlight-color: transparent;
        }

        :root[data-theme="light"] .btn {
            background: rgba(0, 0, 0, .03)
        }

        .btn:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .10)
        }

        :root[data-theme="light"] .btn:hover {
            background: rgba(0, 0, 0, .06)
        }

        .btn.primary {
            border-color: rgba(205, 119, 0, .45);
            background: linear-gradient(135deg, rgba(205, 119, 0, .95), rgba(168, 97, 0, .75));
            box-shadow: 0 18px 40px rgba(205, 119, 0, .18);
        }

        .btn.sm {
            padding: 9px 11px;
            font-size: 13px
        }

        @media (max-width:520px) {
            .btn.hideSmText span.txt {
                display: none
            }

            .btn.hideSmText {
                padding: 10px
            }
        }

        .hamburger {
            display: none
        }

        @media (max-width:920px) {
            .hamburger {
                display: grid
            }
        }

        /* Drawer */
        .drawerBack {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .58);
            display: none;
            z-index: 160;
            align-items: flex-start;
            justify-content: center;
            padding: 74px 16px 22px;
        }

        .drawerBack.open {
            display: flex
        }

        .drawer {
            position: relative;
            width: min(430px, 100%);
            max-height: calc(100vh - 96px);
            overflow: auto;
            background: linear-gradient(180deg, rgba(20, 27, 45, .96), rgba(10, 16, 31, .94));
            border: 1px solid rgba(255, 255, 255, .10);
            border-radius: 28px;
            backdrop-filter: blur(var(--blur));
            -webkit-backdrop-filter: blur(var(--blur));
            transition: transform .24s var(--ease), opacity .24s var(--ease);
            transform: translateY(-16px) scale(.98);
            opacity: 0;
            z-index: 161;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            box-shadow: 0 26px 60px rgba(0, 0, 0, .28);
        }

        :root[data-theme="light"] .drawer {
            background: linear-gradient(180deg, rgba(255, 255, 255, .98), rgba(244, 247, 252, .95));
            border-color: rgba(15, 23, 42, .08);
        }

        .drawerBack.open .drawer {
            transform: translateY(0) scale(1);
            opacity: 1;
        }

        .drawerTop {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 4px 2px 8px;
        }

        .drawerTop b {
            font-size: 14px;
        }

        .drawerBrand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px;
            border-radius: 20px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .06);
        }

        :root[data-theme="light"] .drawerBrand {
            background: rgba(0, 0, 0, .03);
        }

        .drawerLogo {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            display: grid;
            place-items: center;
            font-weight: 900;
            background: linear-gradient(135deg, rgba(205, 119, 0, .95), rgba(168, 97, 0, .75));
            color: #fff;
            box-shadow: 0 10px 24px rgba(205, 119, 0, .22);
            flex-shrink: 0;
        }

        .drawerBrand small {
            display: block;
            color: var(--muted);
            font-size: 12px;
            margin-top: 2px;
        }

        .drawerNav {
            display: grid;
            grid-template-columns: 1fr;
            gap: 10px;
        }

        .drawer a {
            min-height: 74px;
            padding: 14px 14px;
            border: 1px solid var(--line);
            border-radius: 20px;
            background: rgba(255, 255, 255, .05);
            color: var(--text);
            font-weight: 800;
            display: grid;
            grid-template-columns: 40px minmax(0, 1fr);
            align-items: center;
            gap: 12px;
            transition: transform .18s var(--ease), background .18s var(--ease), border-color .18s var(--ease);
        }

        .drawer a .drawerLinkIcon {
            width: 36px;
            height: 36px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .06);
            font-size: 15px;
        }

        .drawer a .drawerLinkMeta {
            display: block;
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
            margin-top: 3px;
        }

        .drawer a:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .09);
            border-color: rgba(205, 119, 0, .28);
        }

        :root[data-theme="light"] .drawer a {
            background: rgba(0, 0, 0, .03);
        }

        :root[data-theme="light"] .drawer a .drawerLinkIcon {
            background: #fff;
        }

        .drawerQuick {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 4px;
        }

        .drawerQuick .btn,
        .drawerBottom .btn {
            justify-content: center;
        }

        .drawerBottom {
            margin-top: auto;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            padding-top: 8px;
        }

        .drawerBottom .btn {
            flex: 1;
        }

        @media (max-width:420px) {
            .drawerQuick {
                grid-template-columns: 1fr;
            }
            .drawerBack {
                padding-top: 66px;
                padding-inline: 12px;
            }
            .drawer {
                border-radius: 24px;
                max-height: calc(100vh - 82px);
            }
        }

        /* Panels */
        .panel {
            border: 1px solid var(--line);
            background: linear-gradient(180deg, rgba(255, 255, 255, .08), rgba(255, 255, 255, .05));
            border-radius: var(--r2);
            box-shadow: var(--shadow);
            backdrop-filter: blur(var(--blur));
            -webkit-backdrop-filter: blur(var(--blur));
            overflow: hidden;
            position: relative;
        }

        :root[data-theme="light"] .panel {
            background: linear-gradient(180deg, rgba(255, 255, 255, .82), rgba(255, 255, 255, .58));
        }

        /* ==========================
       HERO SLIDER (improved)
       ========================== */
        main.hero {
            padding: 18px 0 10px
        }

        .heroSlider {
            position: relative;
            border-radius: 30px;
            border: 1px solid var(--line);
            overflow: hidden;
            box-shadow: var(--shadow);
            min-height: 430px;
            background: rgba(255, 255, 255, .05);
            isolation: isolate;
        }

        @media (max-width:720px) {
            .heroSlider {
                min-height: 400px;
            }
 
        }

        .heroSlides {
            position: absolute;
            inset: 0;
            display: grid
        }

        .heroSlide {
            grid-area: 1 / 1;
            opacity: 0;
            transform: scale(1.02);
            transition: opacity .55s var(--ease), transform .75s var(--ease);
        }

        .heroSlide.active {
            opacity: 1;
            transform: scale(1)
        }

        .heroSlide .bg {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center;
            filter: saturate(1.05) contrast(1.05);
            transform: scale(1.03);
        }

        /* cleaner overlay + vignette */
        .heroSlide .overlay:after {
            content: "";
            position: absolute;
            inset: -1px;
            background: radial-gradient(900px 420px at 50% 20%, rgba(255, 255, 255, .08), transparent 60%);
            opacity: .6;
            pointer-events: none;
        }

        :root[data-theme="light"] .heroSlide .overlay {
            background:
                radial-gradient(1200px 700px at 12% 20%, rgba(205, 119, 0, .22), transparent 62%),
                radial-gradient(900px 700px at 88% 30%, rgba(179, 104, 0, .12), transparent 62%),
                linear-gradient(180deg, rgba(255, 255, 255, .62), rgba(255, 255, 255, .86));
        }

        .heroInner {
            position: relative;
            z-index: 2;
            height: 100%;
            display: flex;
            margin-top: -40px;
            align-items: end;
            padding: 18px;
        }

        /* NEW: glass content card inside hero (makes it premium and readable) */
        .heroCardBox {
            max-width: 580px;
            border-radius: 26px;
            border: 1px solid rgba(255, 255, 255, .16);
            background: linear-gradient(180deg, rgba(255, 255, 255, .10), rgba(112, 110, 110, 0));
            backdrop-filter: blur(calc(var(--blur) + 16px));
            -webkit-backdrop-filter: blur(calc(var(--blur) + 86px));
            box-shadow: 0 26px 90px rgba(0, 0, 0, .45);
            padding: 16px;
        }

        :root[data-theme="light"] .heroCardBox {
            border: 1px solid rgba(15, 23, 42, .10);
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.205), rgba(255, 255, 255, 0.253));
            box-shadow: 0 18px 60px rgba(15, 23, 42, .16);
        }

        .heroTopRow {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
            color: var(--muted);
            font-size: 13px;
            margin-bottom: 10px;
        }

        .badgePill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 10px;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(0, 0, 0, .22);
            backdrop-filter: blur(var(--blur));
            font-weight: 900;
            color: var(--text);
        }

        :root[data-theme="light"] .badgePill {
            background: rgba(255, 255, 255, 0)
        }

        .heroTitle {
            margin: 0;
            font-size: clamp(20px, 1.4vw, 20px);
            line-height: 1.02;
            letter-spacing: -1px;
        }

        .heroSub {
            margin: 10px 0 0;
            color: var(--muted);
            font-size: 15px;
            line-height: 1.7;
            max-width: 62ch;
        }

        .heroCTA {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
            margin-top: 14px;
        }

        @media (max-width:520px) {
            .heroCTA .btn {
                flex: 1
            }
        }

        /* NEW: mini stats row inside hero card */
        .heroStats {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 12px;
        }

        .statPill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 10px;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(235, 230, 230, 0.212);
            color: var(--muted);
            font-weight: 800;
            font-size: 12px;
            backdrop-filter: blur(var(--blur));
        }

        :root[data-theme="light"] .statPill {
            background: rgba(255, 255, 255, 0.13)
        }

        .statPill b {
            color: var(--text);
            font-weight: 900
        }


        @media (max-width:640px) {
            .heroCardBox {
                max-width: 360px;
                padding: 12px;
                border-radius: 20px;
            }

            .heroTopRow {
                margin-bottom: 8px;
            }

            .heroTitle {
                font-size: 18px;
                line-height: 1.08;
                letter-spacing: -.5px;
            }

            .heroSub,
            .heroStats {
                display: none;
            }

            .heroCTA {
                margin-top: 10px;
                gap: 8px;
            }
        }

        /* nav */
        .heroNav {
            position: absolute;
            inset: auto 16px 16px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            z-index: 3;
            pointer-events: none;
        }

        .heroNav>* {
            pointer-events: auto
        }

        .heroDots {
            display: flex;
            gap: 8px;
            align-items: center;
            padding: 10px 12px;
            border: 1px solid var(--line);
            border-radius: 999px;
            background: rgba(0, 0, 0, .22);
            backdrop-filter: blur(var(--blur));
        }

        :root[data-theme="light"] .heroDots {
            background: rgba(255, 255, 255, .60)
        }

        .dotBtn {
            width: 10px;
            height: 10px;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .18);
            cursor: pointer;
            transition: transform .18s var(--ease), background .18s var(--ease);
            -webkit-tap-highlight-color: transparent;
        }

        .dotBtn.active {
