            }
        }

        .card {
            border: 1px solid rgba(255, 255, 255, .12);
            background: linear-gradient(180deg, rgba(255, 255, 255, .08), rgba(255, 255, 255, .05));
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 14px 40px rgba(0, 0, 0, .24);
