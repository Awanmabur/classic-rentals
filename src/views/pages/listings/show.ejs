<script>
const drawerBack = document.getElementById('drawerBack');
function setTheme(theme){ document.documentElement.setAttribute('data-theme', theme); try{ localStorage.setItem('cr-theme', theme); }catch(_){} }
(function(){ try{ const saved = localStorage.getItem('cr-theme'); if(saved) document.documentElement.setAttribute('data-theme', saved); }catch(_){} })();
function openDrawer(){ drawerBack?.classList.add('open'); drawerBack?.setAttribute('aria-hidden','false'); }
function closeDrawer(){ drawerBack?.classList.remove('open'); drawerBack?.setAttribute('aria-hidden','true'); }
document.getElementById('menuBtn')?.addEventListener('click', openDrawer);
document.getElementById('closeDrawer')?.addEventListener('click', closeDrawer);
drawerBack?.addEventListener('click', (e) => { if (e.target === drawerBack || e.target.hasAttribute('data-close-drawer')) closeDrawer(); });
document.getElementById('themeBtn')?.addEventListener('click', () => setTheme(document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light'));
document.getElementById('drawerTheme')?.addEventListener('click', () => setTheme(document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light'));
document.getElementById('navSearchBtn')?.addEventListener('click', () => { window.location.href = '/#filters'; });
document.getElementById('navSearchBtnDrawer')?.addEventListener('click', () => { closeDrawer(); window.location.href = '/#filters'; });
for (const id of ['listBtn','footerList','drawerList']) { document.getElementById(id)?.addEventListener('click', () => location.href = '/listings/create'); }
document.getElementById('footerExplore')?.addEventListener('click', () => location.href = '/listings');
document.getElementById('supportBtn')?.addEventListener('click', (e) => { e.preventDefault(); window.location.href = '/#contact'; });
document.getElementById('reportBtn')?.addEventListener('click', (e) => { e.preventDefault(); alert('Open the inquiry box to contact support about this listing.'); });
document.getElementById('termsBtn')?.addEventListener('click', (e) => { e.preventDefault(); alert('Connect this to your terms page.'); });
document.getElementById('aboutBtn')?.addEventListener('click', (e) => { e.preventDefault(); location.href = '/'; });
document.getElementById('year').textContent = new Date().getFullYear();

document.querySelectorAll('[data-image-src]').forEach((btn) => {
  btn.addEventListener('click', () => {
    document.getElementById('listingMainImage').src = btn.getAttribute('data-image-src');
    document.querySelectorAll('[data-image-src]').forEach((node) => node.classList.remove('active'));
    btn.classList.add('active');
  });
});

document.querySelectorAll('[data-converter]').forEach((box) => {
  const amount = Number(box.dataset.amount || 0);
  const currency = String(box.dataset.currency || 'USD').toUpperCase();
  const targetInput = box.querySelector('[data-converter-target]');
  const output = box.querySelector('[data-converter-output]');
  const source = box.querySelector('[data-converter-source]');
  const fallbackRates = {
    USD: { SSP: 1300, UGX: 3800, KES: 130, EUR: 0.92, GBP: 0.79 },
    EUR: { USD: 1.09, SSP: 1417, UGX: 4130, KES: 142, GBP: 0.86 },
    GBP: { USD: 1.27, SSP: 1650, UGX: 4820, KES: 165, EUR: 1.16 },
  };
  let rates = null;
  let liveDate = '';

  const money = (value, code) => new Intl.NumberFormat(undefined, {
    style: 'currency',
    currency: code,
    maximumFractionDigits: ['SSP', 'UGX', 'KES'].includes(code) ? 0 : 2,
  }).format(value);

  const render = (isLive = false) => {
    const target = String(targetInput?.value || 'SSP').toUpperCase();
    if (target === currency) {
      output.textContent = money(amount, currency);
      source.textContent = 'Same currency selected.';
      return;
    }
    const rate = rates?.[target] || fallbackRates[currency]?.[target];
    if (!rate) {
      output.textContent = 'Rate unavailable';
      source.textContent = `No ${currency} to ${target} rate is available right now.`;
      return;
    }
    output.textContent = money(amount * rate, target);
    source.textContent = isLive
      ? `Live market rate loaded${liveDate ? ` for ${liveDate}` : ''}.`
      : 'Estimated fallback rate. Refresh when internet access is available for a live rate.';
  };

  targetInput?.addEventListener('change', () => render(Boolean(rates)));
  render(false);

  fetch(`https://open.er-api.com/v6/latest/${encodeURIComponent(currency)}`)
    .then((res) => res.ok ? res.json() : Promise.reject(new Error('Rate request failed')))
    .then((data) => {
      if (data?.result === 'success' && data?.rates) {
        rates = data.rates;
        liveDate = data.time_last_update_utc ? new Date(data.time_last_update_utc).toLocaleDateString() : '';
        render(true);
      }
    })
    .catch(() => render(false));
});

document.querySelectorAll('[data-vacate-at]').forEach((node) => {
  const target = node.dataset.vacateAt ? new Date(node.dataset.vacateAt).getTime() : 0;
  if (!target) return;
  const render = () => {
    const diff = target - Date.now();
    if (diff <= 0) {
      node.textContent = 'Tenant may have left';
      return;
    }
    const days = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    const minutes = Math.floor((diff % 3600000) / 60000);
    node.textContent = `${days}d ${hours}h ${minutes}m remaining`;
  };
  render();
  setInterval(render, 60000);
});

async function submitLeadRequest(form, fallbackMessage) {
  const payload = Object.fromEntries(new FormData(form).entries());
  const res = await fetch('/api/inquiries/listing/<%= listing._id %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
    body: JSON.stringify(payload)
  });
  const data = await res.json();
  alert(data.message || (data.success ? 'Request sent.' : fallbackMessage));
  if (data?.meta?.redirectUrl) { window.location.href = data.meta.redirectUrl; return; }
  if (data.success) form.reset();
}

document.getElementById('inquiryForm')?.addEventListener('submit', async function(e){
  e.preventDefault();
  try {
    await submitLeadRequest(this, 'Could not send inquiry.');
  } catch (err) {
    alert('Could not send inquiry right now.');
  }
});

document.getElementById('bookingForm')?.addEventListener('submit', async function(e){
  e.preventDefault();
  try {
    await submitLeadRequest(this, 'Could not send booking request.');
  } catch (err) {
    alert('Could not send booking request right now.');
  }
});
</script>
