
<%- include('../../partials/head', { title }) %>
<%- include('../../partials/nav') %>
<%- include('../../partials/toast') %>
<section class="section">
  <div class="wrap">
    <div class="sectionHead"><div><h1>Manage my listings</h1><p style="color:var(--muted);margin:6px 0 0">Edit, review, or remove your current listing inventory.</p></div><a class="btn" href="/listings/create">Create listing</a></div>
    <section class="cardsGrid">
      <% listings.forEach(item => { %>
        <article class="card">
          <div class="thumb"><img src="<%= (item.images?.find(i => i.isPrimary) || item.images?.[0] || {}).url || '/img/placeholder.jpg' %>" alt="<%= item.title %>"></div>
          <div class="cardBody">
            <div class="titleRow"><h3><%= item.title %></h3><span class="badgeSoft"><%= item.status %></span></div>
            <div class="meta"><span><%= item.category %></span><span><%= item.location?.area || '-' %></span></div>
            <div class="priceRow"><div class="price"><%= item.price?.currency || 'USD' %> <%= Number(item.price?.amount || 0).toLocaleString() %></div></div>
            <div class="actionRow" style="margin-top:12px">
              <a class="tinyBtn" href="/listings/<%= item.slug %>">View</a>
              <a class="tinyBtn" href="/listings/<%= item.slug %>/edit">Edit</a>
              <form action="/listings/<%= item._id %>/delete" method="post" onsubmit="return confirm('Delete this listing?')">
                <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
                <button class="tinyBtn danger" type="submit">Delete</button>
              </form>
            </div>
          </div>
        </article>
      <% }) %>
      <% if (!listings.length) { %><div class="emptyState">You have no listings yet.</div><% } %>
    </section>
  </div>
</section>
<%- include('../../partials/footer') %>
