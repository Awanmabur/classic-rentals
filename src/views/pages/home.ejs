<!doctype html>
<html lang="en" data-theme="dark">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Classic Rentals — Premium Rentals Platform</title>
    <meta name="description"
        content="Classic Rentals: cars, houses, land, shops, offices & short-stays in Juba. Verified listings, fast search, premium experience." />
    <meta name="theme-color" content="#070a14" />
    <meta name="color-scheme" content="dark light" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --bg: #070a14;
            --bg2: #060815;
            --card: rgba(255, 255, 255, .07);
            --card2: rgba(255, 255, 255, .10);
            --line: rgba(255, 255, 255, .12);
            --text: #eef2ff;
            --muted: rgba(238, 242, 255, .72);
            --shadow: 0 28px 90px rgba(0, 0, 0, .55);
            --r: 18px;
            --r2: 24px;

            --primary: #0b6fb5;
            --primary2: #05528d;
            --ok: #22c55e;
            --warn: #f59e0b;
            --accent-soft: rgba(11, 111, 181, .16);
            --input-bg: rgba(255, 255, 255, .06);
            --input-bg-strong: rgba(255, 255, 255, .09);
            --option-bg: #0d1324;
            --option-text: #eef2ff;

            --ease: cubic-bezier(.2, .9, .2, 1);
            --wrap: 1180px;
            --g: 14px;
            --pad: 16px;
            --blur: 16px;

            --scroll-pad: 88px;
        }

        :root[data-theme="light"] {
            --bg: #f7f9fc;
            --bg2: #eef3fb;
            --card: rgba(255, 255, 255, .94);
            --card2: #ffffff;
            --line: rgba(15, 23, 42, .08);
            --text: #0f172a;
            --muted: rgba(15, 23, 42, .64);
            --shadow: 0 18px 48px rgba(15, 23, 42, .12);
            --accent-soft: rgba(11, 111, 181, .08);
            --input-bg: #ffffff;
            --input-bg-strong: #f8fafc;
            --option-bg: #ffffff;
            --option-text: #0f172a;
        }

        * {
            box-sizing: border-box
        }

        html {
            scroll-behavior: smooth;
            scroll-padding-top: var(--scroll-pad)
        }

        body {
            margin: 0;
            font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, "Helvetica Neue", Arial;
            background:
                radial-gradient(1200px 700px at 12% 6%, rgba(11, 111, 181, .30), transparent 60%),
                radial-gradient(1000px 600px at 85% 12%, rgba(34, 197, 94, .16), transparent 55%),
                radial-gradient(900px 600px at 50% 110%, rgba(245, 158, 11, .12), transparent 55%),
                linear-gradient(180deg, var(--bg), var(--bg2));
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        a {
            color: inherit;
            text-decoration: none
        }

        button,
        input,
        select {
            font: inherit
        }

        img {
            max-width: 100%;
            display: block
        }

        input,
        select,
        textarea,
        button {
            accent-color: var(--primary);
        }

        select,
        option,
        optgroup {
            color: var(--option-text);
            background: var(--option-bg);
        }

        select {
            appearance: none;
            -webkit-appearance: none;
            background-image: linear-gradient(45deg, transparent 50%, currentColor 50%), linear-gradient(135deg, currentColor 50%, transparent 50%);
            background-position: calc(100% - 18px) calc(50% - 2px), calc(100% - 12px) calc(50% - 2px);
            background-size: 6px 6px, 6px 6px;
            background-repeat: no-repeat;
            padding-right: 28px !important;
        }

        .wrap {
            max-width: var(--wrap);
            margin: 0 auto;
            padding: 0 16px
        }

        @media (max-width:420px) {
            .wrap {
                padding: 0 12px
            }
        }

        .row {
            display: flex;
            align-items: center
        }

        .muted {
            color: var(--muted)
        }

        /* Topbar */
        .topbar {
            position: sticky;
            top: 0;
            z-index: 110;
            content: "";
            /* backdrop-filter: blur(var(--blur));
            -webkit-backdrop-filter: blur(var(--blur)); */
            /* background: transparent; */
            
        }

        :root[data-theme="light"] .topbar {
            background: linear-gradient(180deg, rgba(255, 255, 255, .92), rgba(255, 255, 255, .76));
            border-bottom: 1px solid rgba(15, 23, 42, .06);
        }

        .topbarRow {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 10px 0;
            color: var(--muted);
            font-size: 13px;
            flex-wrap: wrap;
        }

        .chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 10px;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .04);
            white-space: nowrap;
        }

        :root[data-theme="light"] .chip {
            background: rgba(0, 0, 0, .03)
        }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--ok);
            box-shadow: 0 0 0 4px rgba(34, 197, 94, .12)
        }

        .topLinks {
            display: flex;
            gap: 12px;
            align-items: center;
            flex-wrap: wrap
        }

        .link {
            color: var(--text);
            opacity: .9
        }

        .link:hover {
            opacity: 1;
            text-decoration: underline
        }

        @media (max-width:520px) {
            .topLinks {
                display: none
            }
        }

        /* Navbar */
.nav {
    position: sticky;
    top: 44px;
    z-index: 109;
    background: transparent;
    isolation: isolate;
}

.nav::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: -10px;
    bottom: -10px;
    z-index: -1;
    pointer-events: none;

    background: color-mix(in oklab, var(--bg), transparent 90%);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);

    -webkit-mask-image: linear-gradient(
        to bottom,
        transparent 0%,
        #000 16%,
        #000 84%,
        transparent 100%
    );
    mask-image: linear-gradient(
        to bottom,
        transparent 0%,
        #000 16%,
        #000 84%,
        transparent 100%
    );
}

:root[data-theme="light"] .nav::before {
    background: rgba(255, 255, 255, .84);
    border-bottom: 1px solid rgba(15, 23, 42, .06);
}

.navRow {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    position: relative;
    z-index: 1;
}
        @media (max-width:920px) {
            .navRow {
                grid-template-columns: 1fr auto
            }
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 220px
        }

        @media (max-width:920px) {
            .brand {
                min-width: auto
            }
        }

        .logo {
            width: 40px;
            height: 40px;
            border-radius: 14px;
            background:
                radial-gradient(12px 12px at 30% 30%, rgba(255, 255, 255, .9), rgba(255, 255, 255, 0) 60%),
                linear-gradient(135deg, rgba(11, 111, 181, 1), rgba(34, 197, 94, .85));
            box-shadow: 0 12px 30px rgba(0, 0, 0, .35);
            position: relative;
            flex: 0 0 auto;
        }

        .logo:after {
            content: "";
            position: absolute;
            inset: 1px;
            border-radius: 13px;
            border: 1px solid rgba(255, 255, 255, .22)
        }

        .brandTitle {
            display: flex;
            flex-direction: column;
            line-height: 1.1
        }

        .brandTitle b {
            font-size: 15px;
            letter-spacing: .2px
        }

        .brandTitle span {
            font-size: 12px;
            color: var(--muted)
        }

        @media (max-width:420px) {
            .brandTitle span {
                display: none
            }
        }

        .navLinks {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .navLinks a {
            font-size: 14px;
            color: var(--muted);
            padding: 8px 10px;
            border-radius: 12px;
            transition: transform .18s var(--ease), background .18s var(--ease), color .18s var(--ease);
        }

        .navLinks a:hover {
            color: var(--text);
            background: rgba(255, 255, 255, .06);
            transform: translateY(-1px)
        }

        :root[data-theme="light"] .navLinks a:hover {
            background: rgba(0, 0, 0, .04)
        }

        @media (max-width:920px) {
            .navLinks {
                display: none
            }
        }

        .navActions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
            min-width: 220px
        }

        @media (max-width:920px) {
            .navActions {
                min-width: auto
            }
        }

        .iconBtn {
            width: 40px;
            height: 40px;
            border-radius: 14px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .05);
            color: var(--text);
            display: grid;
            place-items: center;
            cursor: pointer;
            transition: transform .18s var(--ease), background .18s var(--ease);
            -webkit-tap-highlight-color: transparent;
        }

        :root[data-theme="light"] .iconBtn {
            background: #ffffff;
            color: #1e293b;
            border-color: rgba(15, 23, 42, .10);
            box-shadow: 0 6px 18px rgba(15, 23, 42, .06);
        }

        .iconBtn:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .08)
        }

        :root[data-theme="light"] .iconBtn:hover {
            background: rgba(0, 0, 0, .05)
        }

        .btn {
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .06);
            color: var(--text);
            padding: 10px 12px;
            border-radius: 14px;
            cursor: pointer;
            transition: transform .18s var(--ease), background .18s var(--ease);
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            font-size: 14px;
            white-space: nowrap;
            -webkit-tap-highlight-color: transparent;
        }

        :root[data-theme="light"] .btn {
            background: rgba(0, 0, 0, .03)
        }

        .btn:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .10)
        }

        :root[data-theme="light"] .btn:hover {
            background: rgba(0, 0, 0, .06)
        }

        .btn.primary {
            border-color: rgba(11, 111, 181, .45);
            background: linear-gradient(135deg, rgba(11, 111, 181, .95), rgba(5, 82, 141, .75));
            box-shadow: 0 18px 40px rgba(11, 111, 181, .18);
        }

        .btn.sm {
            padding: 9px 11px;
            font-size: 13px
        }

        @media (max-width:520px) {
            .btn.hideSmText span.txt {
                display: none
            }

            .btn.hideSmText {
                padding: 10px
            }
        }

        .hamburger {
            display: none
        }

        @media (max-width:920px) {
            .hamburger {
                display: grid
            }
        }

        /* Drawer */
        .drawerBack {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .55);
            display: none;
            z-index: 160
        }

        .drawerBack.open {
            display: block
        }

        .drawer {
            position: fixed;
            top: 0;
            right: -380px;
            width: min(380px, 92vw);
            height: 100vh;
            background: linear-gradient(180deg, rgba(255, 255, 255, .12), rgba(255, 255, 255, .06));
            border-left: 1px solid var(--line);
            backdrop-filter: blur(var(--blur));
            -webkit-backdrop-filter: blur(var(--blur));
            transition: right .28s var(--ease);
            z-index: 161;
            padding: 14px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        :root[data-theme="light"] .drawer {
            background: linear-gradient(180deg, rgba(255, 255, 255, .90), rgba(255, 255, 255, .65))
        }

        .drawerBack.open .drawer {
            right: 0
        }

        .drawerTop {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px
        }

        .drawerTop b {
            font-size: 14px
        }

        .drawer a {
            padding: 12px 12px;
            border: 1px solid var(--line);
            border-radius: 16px;
            background: rgba(255, 255, 255, .05);
            color: var(--text);
            font-weight: 900;
        }

        :root[data-theme="light"] .drawer a {
            background: rgba(0, 0, 0, .03)
        }

        .drawerBottom {
            margin-top: auto;
            display: flex;
            gap: 10px;
            flex-wrap: wrap
        }

        .drawerBottom .btn {
            flex: 1
        }

        /* Panels */
        .panel {
            border: 1px solid var(--line);
            background: linear-gradient(180deg, rgba(255, 255, 255, .08), rgba(255, 255, 255, .05));
            border-radius: var(--r2);
            box-shadow: var(--shadow);
            backdrop-filter: blur(var(--blur));
            -webkit-backdrop-filter: blur(var(--blur));
            overflow: hidden;
            position: relative;
        }

        :root[data-theme="light"] .panel {
            background: linear-gradient(180deg, rgba(255, 255, 255, .82), rgba(255, 255, 255, .58));
        }

        /* ==========================
       HERO SLIDER (improved)
       ========================== */
        main.hero {
            padding: 18px 0 10px
        }

        .heroSlider {
            position: relative;
            border-radius: 30px;
            border: 1px solid var(--line);
            overflow: hidden;
            box-shadow: var(--shadow);
            min-height: 430px;
            background: rgba(255, 255, 255, .05);
            isolation: isolate;
        }

        @media (max-width:720px) {
            .heroSlider {
                min-height: 400px;
            }
 
        }

        .heroSlides {
            position: absolute;
            inset: 0;
            display: grid
        }

        .heroSlide {
            grid-area: 1 / 1;
            opacity: 0;
            transform: scale(1.02);
            transition: opacity .55s var(--ease), transform .75s var(--ease);
        }

        .heroSlide.active {
            opacity: 1;
            transform: scale(1)
        }

        .heroSlide .bg {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center;
            filter: saturate(1.05) contrast(1.05);
            transform: scale(1.03);
        }

        /* cleaner overlay + vignette */
        .heroSlide .overlay:after {
            content: "";
            position: absolute;
            inset: -1px;
            background: radial-gradient(900px 420px at 50% 20%, rgba(255, 255, 255, .08), transparent 60%);
            opacity: .6;
            pointer-events: none;
        }

        :root[data-theme="light"] .heroSlide .overlay {
            background:
                radial-gradient(1200px 700px at 12% 20%, rgba(11, 111, 181, .22), transparent 62%),
                radial-gradient(900px 700px at 88% 30%, rgba(34, 197, 94, .12), transparent 62%),
                linear-gradient(180deg, rgba(255, 255, 255, .62), rgba(255, 255, 255, .86));
        }

        .heroInner {
            position: relative;
            z-index: 2;
            height: 100%;
            display: flex;
            margin-top: -40px;
            align-items: end;
            padding: 18px;
        }

        /* NEW: glass content card inside hero (makes it premium and readable) */
        .heroCardBox {
            max-width: 580px;
            border-radius: 26px;
            border: 1px solid rgba(255, 255, 255, .16);
            background: linear-gradient(180deg, rgba(255, 255, 255, .10), rgba(112, 110, 110, 0));
            backdrop-filter: blur(calc(var(--blur) + 16px));
            -webkit-backdrop-filter: blur(calc(var(--blur) + 86px));
            box-shadow: 0 26px 90px rgba(0, 0, 0, .45);
            padding: 16px;
        }

        :root[data-theme="light"] .heroCardBox {
            border: 1px solid rgba(15, 23, 42, .10);
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.205), rgba(255, 255, 255, 0.253));
            box-shadow: 0 18px 60px rgba(15, 23, 42, .16);
        }

        .heroTopRow {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
            color: var(--muted);
            font-size: 13px;
            margin-bottom: 10px;
        }

        .badgePill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 10px;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(0, 0, 0, .22);
            backdrop-filter: blur(var(--blur));
            font-weight: 900;
            color: var(--text);
        }

        :root[data-theme="light"] .badgePill {
            background: rgba(255, 255, 255, 0)
        }

        .heroTitle {
            margin: 0;
            font-size: clamp(20px, 1.4vw, 20px);
            line-height: 1.02;
            letter-spacing: -1px;
        }

        .heroSub {
            margin: 10px 0 0;
            color: var(--muted);
            font-size: 15px;
            line-height: 1.7;
            max-width: 62ch;
        }

        .heroCTA {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
            margin-top: 14px;
        }

        @media (max-width:520px) {
            .heroCTA .btn {
                flex: 1
            }
        }

        /* NEW: mini stats row inside hero card */
        .heroStats {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 12px;
        }

        .statPill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 10px;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(235, 230, 230, 0.212);
            color: var(--muted);
            font-weight: 800;
            font-size: 12px;
            backdrop-filter: blur(var(--blur));
        }

        :root[data-theme="light"] .statPill {
            background: rgba(255, 255, 255, 0.13)
        }

        .statPill b {
            color: var(--text);
            font-weight: 900
        }

        /* nav */
        .heroNav {
            position: absolute;
            inset: auto 16px 16px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            z-index: 3;
            pointer-events: none;
        }

        .heroNav>* {
            pointer-events: auto
        }

        .heroDots {
            display: flex;
            gap: 8px;
            align-items: center;
            padding: 10px 12px;
            border: 1px solid var(--line);
            border-radius: 999px;
            background: rgba(0, 0, 0, .22);
            backdrop-filter: blur(var(--blur));
        }

        :root[data-theme="light"] .heroDots {
            background: rgba(255, 255, 255, .60)
        }

        .dotBtn {
            width: 10px;
            height: 10px;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .18);
            cursor: pointer;
            transition: transform .18s var(--ease), background .18s var(--ease);
            -webkit-tap-highlight-color: transparent;
        }

        .dotBtn.active {
            background: rgba(11, 111, 181, .95);
            border-color: rgba(11, 111, 181, .45);
            transform: scale(1.06);
        }

        .heroArrows {
            display: flex;
            gap: 10px;
            align-items: center
        }

        /* ==========================
       FILTER BAR (refined)
       ========================== */
        .filtersWrap {
            padding: 14px 0 12px
        }

        .filtersBar {
            position: sticky;
            top: calc(44px + 56px);
            z-index: 108;
        }

        @media (max-width:920px) {
            .filtersBar {
                top: calc(44px + 58px)
            }
        }

        .filtersShell {
            border-radius: 30px;
            padding: 1px;
            background: linear-gradient(135deg, rgba(11, 111, 181, .42), rgba(34, 197, 94, .14), rgba(245, 158, 11, .12));
            box-shadow: 0 18px 70px rgba(0, 0, 0, .22);
        }

        :root[data-theme="light"] .filtersShell {
            box-shadow: 0 16px 55px rgba(15, 23, 42, .12);
        }

        .filtersCard {
            border-radius: 29px;
            border: 1px solid rgba(255, 255, 255, .10);
            background: linear-gradient(180deg, rgba(7, 14, 26, .78), rgba(7, 14, 26, .62));
            backdrop-filter: blur(calc(var(--blur) + 4px));
            -webkit-backdrop-filter: blur(calc(var(--blur) + 4px));
            padding: 14px;
        }

        :root[data-theme="light"] .filtersCard {
            border: 1px solid rgba(15, 23, 42, .10);
            background: linear-gradient(180deg, rgba(255, 255, 255, .92), rgba(248, 250, 252, .86));
        }

        .filtersTop {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 14px;
            align-items: center;
            margin-bottom: 14px;
        }

        @media (max-width:880px) {
            .filtersTop {
                grid-template-columns: 1fr;
            }
        }

        .filtersTitle {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .filtersTitleWrap {
            min-width: 0;
        }

        .filtersTitle b {
            display: block;
            font-size: 15px;
            line-height: 1.2;
        }

        .filtersTitle .muted {
            font-size: 12px;
            line-height: 1.5;
            margin-top: 2px;
        }

        .miniIco {
            width: 42px;
            height: 42px;
            border-radius: 16px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .06);
            display: grid;
            place-items: center;
            flex: 0 0 auto;
        }

        :root[data-theme="light"] .miniIco {
            background: rgba(0, 0, 0, .03)
        }

        .filtersRight {
            display: flex;
            gap: 10px;
            align-items: center;
            justify-content: flex-end;
            flex-wrap: wrap;
        }

        .filterGrid {
            display: grid;
            grid-template-columns: minmax(0, 1.55fr) repeat(4, minmax(0, 1fr));
            gap: 10px;
            align-items: stretch;
        }

        @media (max-width:1150px) {
            .filterGrid {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }

            .field.searchField {
                grid-column: 1 / -1;
            }
        }

        @media (max-width:760px) {
            .filterGrid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width:520px) {
            .filterGrid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width:380px) {
            .filterGrid {
                grid-template-columns: 1fr;
            }
        }

        .field {
            border: 1px solid rgba(255, 255, 255, .12);
            background: var(--input-bg);
            border-radius: 18px;
            padding: 10px 12px;
            display: grid;
            grid-template-columns: 18px 1fr;
            grid-template-rows: auto auto;
            column-gap: 9px;
            row-gap: 4px;
            min-height: 58px;
            transition: border-color .18s var(--ease), background .18s var(--ease), transform .18s var(--ease), box-shadow .18s var(--ease);
        }

        :root[data-theme="light"] .field {
            border-color: rgba(15, 23, 42, .10);
        }

        .field:focus-within {
            border-color: rgba(11, 111, 181, .55);
            background: var(--input-bg-strong);
            box-shadow: 0 0 0 4px rgba(11, 111, 181, .12);
            transform: translateY(-1px);
        }

        .fIco {
            grid-row: 1 / span 2;
            align-self: center;
            opacity: .9;
            color: var(--muted);
        }

        .field label {
            grid-column: 2;
            font-size: 10px;
            color: var(--muted);
            letter-spacing: .22px;
            text-transform: uppercase;
        }

        .field input,
        .field select {
            grid-column: 2;
            width: 100%;
            background: transparent;
            border: 0;
            outline: none;
            color: var(--text);
            font-weight: 800;
            font-size: 13px;
            min-height: 20px;
            line-height: 1.2;
            padding: 0;
        }

        .field select {
            cursor: pointer;
            appearance: none;
            -webkit-appearance: none;
            padding-right: 24px !important;
            background-image: linear-gradient(45deg, transparent 50%, currentColor 50%), linear-gradient(135deg, currentColor 50%, transparent 50%);
            background-position: calc(100% - 14px) calc(50% - 1px), calc(100% - 8px) calc(50% - 1px);
            background-size: 7px 7px, 7px 7px;
            background-repeat: no-repeat;
        }

        .field input::placeholder {
            color: rgba(238, 242, 255, .45)
        }

        :root[data-theme="light"] .field input::placeholder {
            color: rgba(11, 18, 32, .40)
        }

        .filtersActions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            margin-top: 12px;
        }

        .leftActions,
        .rightActions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
        }

        .rightActions {
            justify-content: flex-end;
        }

        @media (max-width:640px) {
            .filtersActions {
                display: none;
            }
        }

        .cats {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid var(--line);
        }

        @media (max-width:640px) {
            .cats {
                display: none !important;
            }
        }

        .catChip {
            appearance: none;
            -webkit-appearance: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, .12);
            background: rgba(255, 255, 255, .05);
            cursor: pointer;
            transition: transform .18s var(--ease), background .18s var(--ease), border-color .18s var(--ease), box-shadow .18s var(--ease);
            user-select: none;
            font-weight: 900;
            font-size: 13px;
            color: var(--text);
            -webkit-tap-highlight-color: transparent;
        }

        :root[data-theme="light"] .catChip {
            background: rgba(0, 0, 0, .03);
            border-color: rgba(15, 23, 42, .10)
        }

        .catChip:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .09)
        }

        .catChip.active {
            border-color: rgba(11, 111, 181, .5);
            background: rgba(11, 111, 181, .10);
            box-shadow: 0 0 0 4px rgba(11, 111, 181, .12)
        }

        .catIco {
            width: 30px;
            height: 30px;
            border-radius: 999px;
            background: rgba(11, 111, 181, .18);
            border: 1px solid rgba(11, 111, 181, .35);
            display: grid;
            place-items: center;
            flex: 0 0 auto;
            font-size: 13px;
        }

        @media (max-width:420px) {
            .catChip {
                flex: 1
            }
        }
        .sourceRow {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin: 0 0 10px;
        }

        .sourcePill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 8px;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .05);
            color: var(--muted);
            font-size: 11px;
            font-weight: 900;
            letter-spacing: .15px;
        }

        .sourcePill.airbnb {
            color: #ff5a5f;
            border-color: rgba(255, 90, 95, .35);
            background: rgba(255, 90, 95, .10);
        }

        :root[data-theme="light"] .sourcePill {
            background: rgba(0, 0, 0, .03);
        }


        :root[data-theme="light"] .chip,
        :root[data-theme="light"] .btn,
        :root[data-theme="light"] .field,
        :root[data-theme="light"] .searchbar,
        :root[data-theme="light"] .heroCard,
        :root[data-theme="light"] .filterShell,
        :root[data-theme="light"] .filters,
        :root[data-theme="light"] .toolbar .btn {
            box-shadow: none;
        }

        /* Sections */
        section {
            padding: 18px 0
        }

        .secHead {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 12px;
            margin-bottom: 12px;
            flex-wrap: wrap;
        }

        .secHead h2 {
            margin: 0;
            font-size: 20px;
            letter-spacing: -.2px
        }

        .secHead p {
            margin: 0;
            color: var(--muted);
            font-size: 13px;
            max-width: 60ch
        }

        .toolbar {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: flex-end
        }

        /* Listing grid */
        .grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: var(--g)
        }

        @media (max-width:1100px) {
            .grid {
                grid-template-columns: repeat(3, 1fr)
            }
        }

        @media (max-width:820px) {
            .grid {
                grid-template-columns: repeat(2, 1fr)
            }
        }

        @media (max-width:420px) {
            .grid {
                grid-template-columns: 1fr
            }
        }

        .card {
            border: 1px solid rgba(255, 255, 255, .12);
            background: linear-gradient(180deg, rgba(255, 255, 255, .08), rgba(255, 255, 255, .05));
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 14px 40px rgba(0, 0, 0, .24);
            transition: transform .2s var(--ease), box-shadow .2s var(--ease), border-color .2s var(--ease);
            cursor: pointer;
            position: relative;
            min-width: 0;
        }

        :root[data-theme="light"] .card {
            background: linear-gradient(180deg, rgba(255, 255, 255, .98), rgba(248, 250, 252, .98));
            border-color: rgba(15, 23, 42, .08);
            box-shadow: 0 14px 34px rgba(15, 23, 42, .08)
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 24px 65px rgba(0, 0, 0, .30);
            border-color: rgba(11, 111, 181, .22)
        }

        :root[data-theme="light"] .card:hover {
            box-shadow: 0 22px 44px rgba(15, 23, 42, .12);
            border-color: rgba(11, 111, 181, .18)
        }

        .thumb {
            height: 182px;
            background:
                radial-gradient(400px 180px at 20% 0%, rgba(11, 111, 181, .30), transparent 60%),
                radial-gradient(400px 180px at 80% 10%, rgba(34, 197, 94, .20), transparent 60%),
                linear-gradient(135deg, rgba(255, 255, 255, .08), rgba(255, 255, 255, .02));
            border-bottom: 1px solid var(--line);
            position: relative;
            overflow: hidden;
        }

        @media (max-width:420px) {
            .thumb {
                height: 200px
            }
        }

        .thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: saturate(1.05) contrast(1.05);
            opacity: .92
        }

        .thumb .badgeRow {
            position: absolute;
            inset: 12px 12px auto 12px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .b {
            font-size: 11px;
            font-weight: 900;
            padding: 6px 10px;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(0, 0, 0, .35);
            color: var(--text);
            backdrop-filter: blur(var(--blur));
            white-space: nowrap;
        }

        :root[data-theme="light"] .b {
            background: rgba(255, 255, 255, .70)
        }

        .b.ok {
            border-color: rgba(34, 197, 94, .4)
        }

        .b.feat {
            border-color: rgba(245, 158, 11, .45)
        }

        .b.new {
            border-color: rgba(11, 111, 181, .45)
        }

        .cardBody {
            padding: 15px
        }

        .titleRow {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 8px
        }

        .card h3 {
            margin: 0;
            font-size: 15px;
            letter-spacing: -.2px;
            line-height: 1.25;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .fav {
            width: 32px;
            height: 32px;
            border-radius: 12px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .05);
            color: rgba(238, 242, 255, .92);
            display: grid;
            place-items: center;
            cursor: pointer;
            transition: transform .18s var(--ease), background .18s var(--ease), color .18s var(--ease), border-color .18s var(--ease), box-shadow .18s var(--ease);
            flex: 0 0 auto;
            -webkit-tap-highlight-color: transparent;
        }

        :root[data-theme="light"] .fav {
            background: #ffffff;
            color: #334155;
            border-color: rgba(15, 23, 42, .12);
            box-shadow: 0 6px 18px rgba(15, 23, 42, .07);
        }

        .fav svg,
        .iconBtn svg,
        .modalClose svg {
            display: block;
        }

        .fav:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .10)
        }

        :root[data-theme="light"] .fav:hover {
            background: #f8fafc;
            color: #0f172a;
            border-color: rgba(11, 111, 181, .18);
        }

        .fav.active {
            color: #ff5a5f;
            background: rgba(255, 90, 95, .14);
            border-color: rgba(255, 90, 95, .45);
            box-shadow: 0 0 0 4px rgba(255, 90, 95, .12)
        }

        .fav.active svg,
        .iconBtn.active svg,
        .modalClose:hover svg {
            filter: none;
        }

        .fav.active path,
        .iconBtn.active path {
            fill: currentColor;
            stroke: currentColor;
        }

        .meta {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            color: var(--muted);
            font-size: 12px;
            margin-bottom: 10px
        }

        .meta span {
            display: inline-flex;
            align-items: center;
            gap: 7px
        }

        .priceRow {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            padding-top: 10px;
            border-top: 1px solid var(--line)
        }

        .price {
            font-weight: 900;
            letter-spacing: -.2px;
            font-size: 14px
        }

        .per {
            color: var(--muted);
            font-weight: 800;
            font-size: 12px
        }

        .tinyBtn {
            padding: 8px 10px;
            border-radius: 14px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .05);
            color: var(--text);
            cursor: pointer;
            font-weight: 900;
            font-size: 12px;
            transition: transform .18s var(--ease), background .18s var(--ease);
            -webkit-tap-highlight-color: transparent;
        }

        .tinyBtn:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .10)
        }

        /* Why */
        .whyGrid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--g)
        }

        @media (max-width:980px) {
            .whyGrid {
                grid-template-columns: 1fr
            }
        }

        .why {
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .06);
            border-radius: 22px;
            padding: 16px;
        }

        :root[data-theme="light"] .why {
            background: rgba(255, 255, 255, .84)
        }

        .why b {
            display: block;
            margin-bottom: 8px
        }

        .why p {
            margin: 0;
            color: var(--muted);
            font-size: 13px;
            line-height: 1.65
        }

        /* Footer */
        footer {
            padding: 24px 0 34px;
            border-top: 1px solid var(--line);
            margin-top: 18px;
            background: rgba(0, 0, 0, .12);
            backdrop-filter: blur(var(--blur));
            -webkit-backdrop-filter: blur(var(--blur));
        }

        :root[data-theme="light"] footer {
            background: rgba(255, 255, 255, .60)
        }

        .footTop {
            display: grid;
            grid-template-columns: 1.2fr .8fr 1fr 1fr;
            gap: var(--g);
            margin-bottom: 16px
        }

        @media (max-width:980px) {
            .footTop {
                grid-template-columns: 1fr 1fr
            }
        }

        @media (max-width:520px) {
            .footTop {
                grid-template-columns: 1fr
            }
        }

        .footBox {
            border: 1px solid var(--line);
            border-radius: 22px;
            background: rgba(255, 255, 255, .05);
            padding: 14px;
        }

        :root[data-theme="light"] .footBox {
            background: rgba(0, 0, 0, .03)
        }

        .footBox h4 {
            margin: 0 0 10px;
            font-size: 14px
        }

        .footBox a {
            display: block;
            padding: 7px 0;
            color: var(--muted);
            font-size: 13px
        }

        .footBox a:hover {
            color: var(--text);
            text-decoration: underline
        }

        .fine {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            color: var(--muted);
            font-size: 12px;
        }

        .socials {
            display: flex;
            gap: 10px;
            align-items: center
        }

        .soc {
            width: 40px;
            height: 40px;
            border-radius: 14px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .05);
            display: grid;
            place-items: center;
            transition: transform .18s var(--ease), background .18s var(--ease);
            -webkit-tap-highlight-color: transparent;
        }

        :root[data-theme="light"] .soc {
            background: rgba(0, 0, 0, .03)
        }

        .soc:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .10)
        }

        :root[data-theme="light"] .soc:hover {
            background: rgba(0, 0, 0, .05)
        }

        /* Modal (unchanged) */
        .modalBack {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .60);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 16px;
            z-index: 200;
            overflow: auto;
        }

        .modalBack.open {
            display: flex
        }

        .modal {
            width: min(1180px, 100%);
            border-radius: 28px;
            border: 1px solid var(--line);
            background: #0b1020;
            backdrop-filter: blur(var(--blur));
            -webkit-backdrop-filter: blur(var(--blur));
            box-shadow: var(--shadow);
            overflow: hidden;
            max-height: calc(100vh - 40px);
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        :root[data-theme="light"] .modal {
            background: #ffffff;
            border-color: rgba(15, 23, 42, .10);
            box-shadow: 0 28px 70px rgba(15, 23, 42, .18);
        }

        .modalTop {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 14px 18px;
            border-bottom: 1px solid var(--line);
            background: inherit;
            flex: 0 0 auto
        }

        .modalTop b {
            font-size: 14px
        }

        .modalClose {
            width: 40px;
            height: 40px;
            border-radius: 14px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .05);
            color: var(--text);
            cursor: pointer;
            -webkit-tap-highlight-color: transparent
        }

        :root[data-theme="light"] .modalClose {
            color: #000;
            background: #ffffff;
            border-color: rgba(15, 23, 42, .12);
            box-shadow: 0 6px 18px rgba(15, 23, 42, .08);
        }
        :root[data-theme="light"] #modalFav {
            background: #ffffff;
            color: #334155;
            border-color: rgba(15, 23, 42, .12);
            box-shadow: 0 6px 18px rgba(15, 23, 42, .07);
        }

        .modalGrid {
            display: grid;
            grid-template-columns: minmax(0, 1.18fr) minmax(340px, .82fr);
            gap: 16px;
            padding: 16px 18px 18px;
            overflow: auto;
            background: inherit;
            align-items: start;
        }

        .details {
            min-width: 0;
        }

        @media (max-width:920px) {
            .modalGrid {
                grid-template-columns: 1fr
            }

            .details {
                padding-bottom: 18px;
            }
        }

        @media (max-width:640px) {
            .modalBack {
                padding: 0;
                align-items: stretch;
                overflow-y: auto;
                -webkit-overflow-scrolling: touch;
            }

            .modal {
                width: 100%;
                height: auto;
                max-height: none;
                min-height: 100vh;
                border-radius: 0;
                overflow: visible;
            }

            .modalTop {
                padding: 12px;
                position: sticky;
                top: 0;
                background: inherit;
                z-index: 5;
            }

            .modalGrid {
                padding: 10px 12px 20px;
                gap: 10px;
                overflow: visible;
            }

            .thumbs {
                gap: 4px;
                padding: 5px;
            }

            .t {
                height: 42px;
            }
        }

        .gallery {
            border: 1px solid var(--line);
            border-radius: 22px;
            overflow: hidden;
            background: rgba(255, 255, 255, .06);
            min-width: 0
        }

        :root[data-theme="light"] .gallery {
            background: #f8fafc;
            border-color: rgba(15, 23, 42, .08);
        }

        .galleryMain {
            height: 340px;
            background: rgba(2, 6, 23, .35);
            border-bottom: 1px solid var(--line);
            position: relative
        }

        :root[data-theme="light"] .galleryMain {
            background: #e2e8f0;
        }

        @media (max-width:520px) {
            .galleryMain {
                height: 260px
            }
        }

        .galleryMain img {
            width: 100%;
            height: 100%;
            object-fit: cover
        }

        .thumbs {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 6px;
            padding: 6px
        }

        @media (max-width:520px) {
            .thumbs {
                grid-template-columns: repeat(3, 1fr)
            }
        }

        .t {
            height: 50px;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--line);
            cursor: pointer;
            opacity: .85;
            transition: opacity .18s var(--ease), transform .18s var(--ease);
            -webkit-tap-highlight-color: transparent
        }

        .t:hover {
            opacity: 1;
            transform: translateY(-1px)
        }

        .t.active {
            opacity: 1;
            box-shadow: 0 0 0 4px rgba(11, 111, 181, .12);
            border-color: rgba(11, 111, 181, .45)
        }

        .t img {
            width: 100%;
            height: 100%;
            object-fit: cover
        }

        .details {
            border: 1px solid var(--line);
            border-radius: 22px;
            background: rgba(255, 255, 255, .05);
            padding: 14px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            min-width: 0
        }

        :root[data-theme="light"] .details {
            background: rgba(0, 0, 0, .03)
        }

        .details .row {
            justify-content: space-between;
            gap: 10px;
            flex-wrap: wrap
        }

        .kv {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            padding-top: 10px;
            border-top: 1px solid var(--line);
            color: var(--muted);
            font-size: 12px
        }

        .kv .k {
            padding: 8px 10px;
            border: 1px solid var(--line);
            border-radius: 999px;
            background: rgba(255, 255, 255, .05);
            white-space: nowrap
        }

        :root[data-theme="light"] .kv .k {
            background: rgba(255, 255, 255, .75)
        }

        .agent {
            border-top: 1px solid var(--line);
            padding-top: 10px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            flex-wrap: wrap
        }

        .agentCard {
            display: flex;
            gap: 10px;
            align-items: center
        }

        .avatar {
            width: 44px;
            height: 44px;
            border-radius: 16px;
            background: radial-gradient(10px 10px at 30% 30%, rgba(255, 255, 255, .85), rgba(255, 255, 255, 0) 60%), linear-gradient(135deg, rgba(11, 111, 181, .9), rgba(34, 197, 94, .7));
            border: 1px solid rgba(255, 255, 255, .2);
            flex: 0 0 auto
        }

        .ico {
            width: 18px;
            height: 18px;
            display: inline-block;
            vertical-align: middle;
            flex: 0 0 auto;
        }

        .ico * {
            vector-effect: non-scaling-stroke;
            stroke-linecap: round;
            stroke-linejoin: round;
            shape-rendering: geometricPrecision;
        }

        .meta .ico,
        .priceRow .ico,
        .kv .ico {
            opacity: .92;
        }

        .ico.sm {
            width: 16px;
            height: 16px
        }

        @media (prefers-reduced-motion: reduce) {
            * {
                scroll-behavior: auto !important
            }

            .card,
            .btn,
            .iconBtn,
            .t,
            .dotBtn,
            .catChip {
                transition: none !important
            }

            .heroSlide {
