                            <div>
                                <b id="agentName" style="display:block">Agent</b>
                                <span class="muted" id="agentMeta">Verified • Avg response 12 mins</span>
                            </div>
                        </div>
                        <div style="display:flex; gap:10px; flex-wrap:wrap;">
                            <button class="btn" id="messageBtn" type="button">Message</button>
                            <button class="btn ghost" id="reportListing" type="button">Report</button>
                        </div>
                    </div>

                    <div style="display:flex; gap:10px; flex-wrap:wrap;">
                        <button class="btn" id="copyLink" style="flex:1" type="button">Copy link</button>
                        <button class="btn" id="shareBtn" style="flex:1" type="button">Share</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    
<script>
const LISTINGS = <%- homeListingsJson %>;
const FAVORITE_IDS = <%- favoriteIdsJson %>;
const AREA_LABEL = <%- areaLabelsJson %>;
const IS_AUTHENTICATED = <%- JSON.stringify(Boolean(currentUser)) %>;
const POST_LIST_URL = <%- JSON.stringify(currentUser ? '/listings/create' : '/auth/register') %>;
const LOGIN_URL = '/auth/login';
const PLACEHOLDER_IMAGE = '/img/placeholder.jpg';

const TYPE_LABEL = {
  all: 'All',
  car: 'Car Rental',
  house: 'House',
  apartment: 'Apartment',
  land: 'Land / Plot',
  shop: 'Shop',
  office: 'Office',
  warehouse: 'Warehouse',
  shortstay: 'Short-Stay'
};
const PLATFORM_LABEL = { airbnb: 'Airbnb', direct: 'Direct', agent: 'Agent' };
const el = (id) => document.getElementById(id);

const state = {
  q: '',
  category: 'all',
  area: 'all',
  verifiedOnly: false,
  sort: 'featured',
  price: 'all',
  favorites: new Set(FAVORITE_IDS),
  newestLimit: 8,
};

function money(n, currency = 'USD') {
  const num = Number(n);
  if (!Number.isFinite(num)) return `${currency} —`;
  return `${currency} ${num.toLocaleString()}`;
}
function daysAgo(iso) {
  const d = new Date(String(iso).includes('T') ? iso : iso + 'T00:00:00');
  const now = new Date();
  return Math.floor((now - d) / (1000 * 60 * 60 * 24));
}
function escapeHtml(s) {
  return String(s ?? '')
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');
}
function toast(msg, error = false) {
  let t = document.getElementById('toast');
  if (!t) {
    t = document.createElement('div');
    t.id = 'toast';
    t.style.position = 'fixed';
    t.style.left = '50%';
    t.style.bottom = '20px';
    t.style.transform = 'translateX(-50%)';
    t.style.padding = '12px 14px';
    t.style.borderRadius = '16px';
    t.style.border = '1px solid var(--line)';
    t.style.background = error ? 'rgba(127,29,29,.88)' : 'rgba(0,0,0,.55)';
    t.style.backdropFilter = 'blur(var(--blur))';
    t.style.color = 'var(--text)';
    t.style.zIndex = '300';
    t.style.fontWeight = '800';
    t.style.boxShadow = 'var(--shadow)';
    document.body.appendChild(t);
  }
  t.textContent = msg;
  t.style.background = error ? 'rgba(127,29,29,.88)' : 'rgba(0,0,0,.55)';
  t.style.opacity = '1';
  clearTimeout(window.__jrToastTimer);
  window.__jrToastTimer = setTimeout(() => { t.style.opacity = '0'; }, 2400);
}
function setTheme(theme) {
  document.documentElement.setAttribute('data-theme', theme);
  localStorage.setItem('cr_theme', theme);
}
const savedTheme = localStorage.getItem('cr_theme');
if (savedTheme === 'light' || savedTheme === 'dark') setTheme(savedTheme);

function populateDynamicAreas() {
  const areaSelect = el('area');
  if (!areaSelect) return;
  areaSelect.innerHTML = Object.entries(AREA_LABEL)
    .map(([key, label]) => `<option value="${escapeHtml(key)}">${escapeHtml(label)}</option>`)
    .join('');
}

function badgeHTML(item) {
  const parts = [];
  if (item.featured) parts.push('<span class="b feat">FEATURED</span>');
  if (item.verified) parts.push('<span class="b ok">VERIFIED</span>');
  if (daysAgo(item.createdAt) <= 4) parts.push('<span class="b new">NEW</span>');
  return parts.join('');
}
function matchesFilters(item) {
  if (state.category !== 'all' && item.type !== state.category) return false;
  if (state.area !== 'all' && item.area !== state.area) return false;
  if (state.verifiedOnly && !item.verified) return false;
  if (state.price !== 'all') {
    const [min, max] = state.price.split('-').map(Number);
    if (!(Number(item.price) >= min && Number(item.price) <= max)) return false;
  }
  const q = state.q.trim().toLowerCase();
  if (q) {
    const hay = [
      item.title, item.desc, item.id, item.areaLabel, item.city,
      TYPE_LABEL[item.type], ...(item.tags || []), item.agent?.name || ''
    ].join(' ').toLowerCase();
    if (!hay.includes(q)) return false;
  }
  return true;
}
function sortItems(items) {
  const arr = [...items];
  switch (state.sort) {
    case 'newest':
      arr.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
      break;
    case 'price_low':
      arr.sort((a, b) => Number(a.price) - Number(b.price));
      break;
    case 'price_high':
      arr.sort((a, b) => Number(b.price) - Number(a.price));
      break;
    default:
      arr.sort((a, b) => {
        const score = (x) => (x.featured ? 20 : 0) + (x.verified ? 10 : 0) + Math.max(0, 10 - daysAgo(x.createdAt));
        return score(b) - score(a);
      });
  }
  return arr;
}
function cardHTML(item) {
  const isFav = state.favorites.has(item.id);
  const img = item.images?.[0] || PLACEHOLDER_IMAGE;
  return `
    <article class="card" data-open="${item.id}">
      <div class="thumb">
        <img loading="lazy" alt="${escapeHtml(item.title)}" src="${img}">
        <div class="badgeRow">${badgeHTML(item)}</div>
      </div>
      <div class="cardBody">
        <div class="titleRow">
          <h3>${escapeHtml(item.title)}</h3>
          <button class="fav ${isFav ? 'active' : ''}" data-fav="${item.id}" aria-label="Favorite" type="button">
            <svg class="ico" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 21s-7-4.6-9.5-9A5.6 5.6 0 0 1 12 5.8 5.6 5.6 0 0 1 21.5 12c-2.5 4.4-9.5 9-9.5 9Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" ${isFav ? 'fill="currentColor"' : ''} />
            </svg>
          </button>
        </div>
        <div class="meta">
          <span>
            <svg class="ico sm" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s-7-4.6-9.5-9A5.6 5.6 0 0 1 12 5.8 5.6 5.6 0 0 1 21.5 12c-2.5 4.4-9.5 9-9.5 9Z" stroke="currentColor" stroke-width="1.7"/></svg>
            ${escapeHtml(item.areaLabel || AREA_LABEL[item.area] || item.area)}
          </span>
          <span>
            <svg class="ico sm" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2 20 6v7c0 5-3.2 9-8 9s-8-4-8-9V6l8-4Z" stroke="currentColor" stroke-width="1.7"/></svg>
            ${item.verified ? 'Verified' : 'Standard'}
          </span>
        </div>
        <div class="priceRow">
          <div>
            <div class="price">${money(item.price, item.currency)} <span class="per">${escapeHtml(item.unit)}</span></div>
            <div class="per">${escapeHtml(TYPE_LABEL[item.type] || item.type)}</div>
          </div>
          <button class="tinyBtn" data-open="${item.id}" type="button">View</button>
        </div>
      </div>
    </article>`;
}
function emptyHTML(msg) {
  return `<div class="panel" style="grid-column:1/-1; padding:16px; border-radius:22px"><b style="display:block; margin-bottom:6px">Nothing here yet</b><span class="muted" style="font-size:13px">${escapeHtml(msg)}</span></div>`;
}
function updateHeroStats() {
  const verifiedCount = LISTINGS.filter((x) => x.verified).length;
  const newCount = LISTINGS.filter((x) => daysAgo(x.createdAt) <= 4).length;
  const cars = LISTINGS.filter((x) => x.type === 'car').length;
  const carVerified = LISTINGS.filter((x) => x.type === 'car' && x.verified).length;
  const commercial = LISTINGS.filter((x) => ['shop', 'office', 'warehouse'].includes(x.type)).length;
  const land = LISTINGS.filter((x) => x.type === 'land').length;
  const counts = LISTINGS.reduce((acc, item) => { acc[item.type] = (acc[item.type] || 0) + 1; return acc; }, {});
  const trending = Object.entries(counts).sort((a,b) => b[1]-a[1])[0]?.[0] || 'shortstay';
  const setTxt = (id, value) => { const n = document.getElementById(id); if (n) n.textContent = String(value); };
  setTxt('statTrending', TYPE_LABEL[trending] || 'Short-Stay');
  setTxt('statVerifiedCount', verifiedCount);
  setTxt('statNewCount', newCount);
  setTxt('statCars', cars);
  setTxt('statCarVerified', carVerified);
  setTxt('statCommercial', commercial);
  setTxt('statLand', land);
}
function render() {
  const filtered = sortItems(LISTINGS.filter(matchesFilters));
  const featured = filtered.filter((x) => x.featured).slice(0, 8);
  el('featuredGrid').innerHTML = featured.length ? featured.map(cardHTML).join('') : emptyHTML('No featured listings match your filters.');
  const newest = LISTINGS.slice().sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt)).filter(matchesFilters).slice(0, state.newestLimit);
  el('newestGrid').innerHTML = newest.length ? newest.map(cardHTML).join('') : emptyHTML('No newest listings match your filters.');
  el('loadMore').disabled = LISTINGS.filter(matchesFilters).length <= state.newestLimit;
  el('loadMore').style.opacity = el('loadMore').disabled ? .6 : 1;
  el('verifiedLabel').textContent = state.verifiedOnly ? 'On' : 'Off';
  el('toggleVerified').setAttribute('aria-pressed', state.verifiedOnly ? 'true' : 'false');
  el('q').value = state.q;
  el('category').value = state.category;
  el('area').value = state.area;
  el('sort').value = state.sort;
  el('price').value = state.price;
  document.querySelectorAll('.catChip').forEach((c) => c.classList.toggle('active', c.dataset.cat === state.category));
  el('year').textContent = new Date().getFullYear().toString();
}

async function toggleFavorite(id) {
  if (!IS_AUTHENTICATED) {
    toast('Please log in to save favorites.', true);
    setTimeout(() => { window.location.href = LOGIN_URL; }, 500);
    return;
  }
  try {
    const res = await fetch(`/api/favorites/${id}/toggle`, { method: 'POST', headers: { Accept: 'application/json' } });
    const data = await res.json();
    if (!data.success) throw new Error(data.message || 'Failed');
    if (data.active) state.favorites.add(id); else state.favorites.delete(id);
    render();
    syncModalFav();
    toast(data.message || 'Favorites updated');
  } catch (err) {
    toast(err.message || 'Could not update favorites right now.', true);
  }
}

el('explore').addEventListener('submit', (e) => {
  e.preventDefault();
  state.q = el('q').value;
  state.category = el('category').value;
  state.area = el('area').value;
  state.sort = el('sort').value;
  state.price = el('price').value;
  state.newestLimit = 8;
  render();
  document.querySelector('#featured').scrollIntoView({ behavior: 'smooth', block: 'start' });
});
el('toggleVerified').addEventListener('click', () => { state.verifiedOnly = !state.verifiedOnly; state.newestLimit = 8; render(); });
el('resetBtn').addEventListener('click', () => { state.q=''; state.category='all'; state.area='all'; state.verifiedOnly=false; state.sort='featured'; state.price='all'; state.newestLimit=8; render(); });
document.querySelectorAll('.catChip').forEach((chip) => chip.addEventListener('click', () => { state.category = chip.dataset.cat; el('category').value = state.category; state.newestLimit = 8; render(); document.querySelector('#featured').scrollIntoView({ behavior:'smooth', block:'start' }); }));
el('loadMore').addEventListener('click', () => { state.newestLimit += 4; render(); });

document.addEventListener('click', (e) => {
  const favBtn = e.target.closest('[data-fav]');
  if (favBtn) {
    e.stopPropagation();
    toggleFavorite(favBtn.dataset.fav);
    return;
  }
  const openBtn = e.target.closest('[data-open]');
  if (openBtn) openListing(openBtn.dataset.open);
});

el('navSearchBtn').addEventListener('click', () => el('filters').scrollIntoView({ behavior: 'smooth' }));
for (const id of ['listBtn','footerList','drawerList']) {
  const node = document.getElementById(id);
  if (node) node.addEventListener('click', () => { window.location.href = POST_LIST_URL; });
}
el('footerExplore').addEventListener('click', () => document.querySelector('#featured').scrollIntoView({ behavior:'smooth', block:'start' }));
document.querySelectorAll('[data-catjump]').forEach((a) => a.addEventListener('click', () => { const cat = a.getAttribute('data-catjump'); state.category = cat || 'all'; el('category').value = state.category; state.newestLimit = 8; render(); }));

const drawerBack = el('drawerBack');
function openDrawer() { drawerBack.classList.add('open'); drawerBack.setAttribute('aria-hidden', 'false'); }
function closeDrawer() { drawerBack.classList.remove('open'); drawerBack.setAttribute('aria-hidden', 'true'); }
el('menuBtn').addEventListener('click', openDrawer);
el('closeDrawer').addEventListener('click', closeDrawer);
drawerBack.addEventListener('click', (e) => { if (e.target === drawerBack || e.target.hasAttribute('data-close-drawer')) closeDrawer(); });
el('drawerTheme').addEventListener('click', () => { const next = (document.documentElement.getAttribute('data-theme') || 'dark') === 'dark' ? 'light' : 'dark'; setTheme(next); });
el('themeBtn').addEventListener('click', () => { const next = (document.documentElement.getAttribute('data-theme') || 'dark') === 'dark' ? 'light' : 'dark'; setTheme(next); });

const heroSlides = [...document.querySelectorAll('.heroSlide')];
const heroDots = [...document.querySelectorAll('[data-hero-dot]')];
let heroIndex = 0; let heroTimer = null;
function goHero(i) { heroIndex = (i + heroSlides.length) % heroSlides.length; heroSlides.forEach((s, idx) => { const active = idx === heroIndex; s.classList.toggle('active', active); s.setAttribute('aria-hidden', active ? 'false' : 'true'); }); heroDots.forEach((d) => d.classList.toggle('active', Number(d.dataset.heroDot) === heroIndex)); }
function nextHero() { goHero(heroIndex + 1); }
function prevHero() { goHero(heroIndex - 1); }
function startHero() { stopHero(); heroTimer = setInterval(nextHero, 5200); }
function stopHero() { if (heroTimer) clearInterval(heroTimer); heroTimer = null; }
el('heroNext').addEventListener('click', () => { nextHero(); startHero(); });
el('heroPrev').addEventListener('click', () => { prevHero(); startHero(); });
heroDots.forEach((d) => d.addEventListener('click', () => { goHero(Number(d.dataset.heroDot)); startHero(); }));
el('heroToFilters').addEventListener('click', () => el('filters').scrollIntoView({ behavior: 'smooth' }));
el('heroViewFeatured').addEventListener('click', () => document.querySelector('#featured').scrollIntoView({ behavior: 'smooth', block: 'start' }));
document.querySelectorAll('[data-hero-apply]').forEach((btn) => btn.addEventListener('click', () => { const cat = btn.getAttribute('data-hero-apply'); state.category = cat; el('category').value = cat; state.newestLimit = 8; render(); el('filters').scrollIntoView({ behavior: 'smooth' }); toast(`Filter applied: ${TYPE_LABEL[cat] || cat}`); }));
const heroSlider = document.querySelector('.heroSlider');
heroSlider.addEventListener('mouseenter', stopHero); heroSlider.addEventListener('mouseleave', startHero); heroSlider.addEventListener('focusin', stopHero); heroSlider.addEventListener('focusout', startHero);

const modalBack = el('modalBack');
el('modalClose').addEventListener('click', closeModal);
modalBack.addEventListener('click', (e) => { if (e.target === modalBack) closeModal(); });
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeModal(); closeDrawer(); } });
let currentModalId = null;
function openListing(id) {
  const item = LISTINGS.find((x) => x.id === id);
  if (!item) return;
  currentModalId = id;
  el('modalTitle').textContent = item.title;
  el('modalPrice').textContent = `${money(item.price, item.currency)} ${item.unit === 'one-time' ? '' : item.unit}`;
  el('modalMeta').textContent = `${TYPE_LABEL[item.type] || item.type} • ${item.areaLabel || AREA_LABEL[item.area] || item.area} • ${item.platform ? ((PLATFORM_LABEL[item.platform.toLowerCase()] || item.platform) + ' • ') : ''}${item.verified ? 'Verified listing' : 'Standard listing'}`;
  el('modalDesc').textContent = item.desc;
  el('agentName').textContent = item.agent?.name || 'Classic Rentals Agent';
  el('agentMeta').textContent = `${item.agent?.verified ? 'Verified' : 'Available'} • Avg response ${item.agent?.responseMins || 8} mins`;
  el('modalTags').innerHTML = (item.tags || []).map((tag) => `<span class="k">${escapeHtml(tag)}</span>`).join('');
  const images = item.images?.length ? item.images : [PLACEHOLDER_IMAGE];
  el('mainImg').src = images[0];
  el('thumbs').innerHTML = images.map((src, idx) => `<button class="t ${idx===0?'active':''}" type="button" data-thumb="${idx}"><img src="${src}" alt="${escapeHtml(item.title)} image ${idx+1}"></button>`).join('');
  el('thumbs').querySelectorAll('[data-thumb]').forEach((btn, idx) => btn.addEventListener('click', () => { el('mainImg').src = images[idx]; el('thumbs').querySelectorAll('[data-thumb]').forEach((x, i) => x.classList.toggle('active', i === idx)); }));
  syncModalFav();
  modalBack.classList.add('open');
  modalBack.setAttribute('aria-hidden', 'false');
}
function closeModal() { currentModalId = currentModalId; modalBack.classList.remove('open'); modalBack.setAttribute('aria-hidden', 'true'); }
function syncModalFav() { const btn = el('modalFav'); btn.classList.toggle('active', Boolean(currentModalId && state.favorites.has(currentModalId))); }
el('modalFav').addEventListener('click', () => { if (!currentModalId) return; toggleFavorite(currentModalId); });

async function sendInquiryFromModal() {
  if (!currentModalId) return;
  const item = LISTINGS.find((x) => x.id === currentModalId);
  const message = window.prompt(`Send an inquiry for "${item?.title || 'this listing'}"`, 'Hello, I am interested in this listing. Is it still available?');
  if (!message) return;
  let name = ''; let email = ''; let phone = '';
  if (!IS_AUTHENTICATED) {
    name = window.prompt('Your name', '') || '';
    email = window.prompt('Your email (optional)', '') || '';
    phone = window.prompt('Your phone (optional)', '') || '';
  }
  try {
    const res = await fetch(`/api/inquiries/listing/${currentModalId}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify({ name, email, phone, message })
    });
    const data = await res.json();
    if (!data.success) throw new Error(data.message || 'Could not send inquiry');
    toast(data.message || 'Inquiry sent successfully');
  } catch (err) {
    toast(err.message || 'Could not send inquiry right now.', true);
  }
}
async function reportCurrentListing() {
  if (!currentModalId) return;
  const reason = window.prompt('Reason for reporting this listing', 'Suspicious or inaccurate information');
  if (!reason) return;
  const details = window.prompt('More details (optional)', '') || '';
  try {
    const res = await fetch(`/api/reports/listing/${currentModalId}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify({ reason, details })
    });
    const data = await res.json();
    if (!data.success) throw new Error(data.message || 'Could not submit report');
    toast(data.message || 'Report submitted');
  } catch (err) {
    toast(err.message || 'Could not submit report.', true);
  }
}
el('contactBtn').addEventListener('click', () => {
  const item = LISTINGS.find((x) => x.id === currentModalId); if (item) window.location.href = item.url;
});
el('messageBtn').addEventListener('click', sendInquiryFromModal);
el('reportListing').addEventListener('click', reportCurrentListing);
el('copyLink').addEventListener('click', async () => {
  const item = LISTINGS.find((x) => x.id === currentModalId); const url = item ? `${location.origin}${item.url}` : location.href;
  try { await navigator.clipboard.writeText(url); toast('Link copied.'); } catch { toast('Copy not supported in this browser.', true); }
});
el('shareBtn').addEventListener('click', async () => {
  const item = LISTINGS.find((x) => x.id === currentModalId); const data = { title: item?.title || 'Classic Rentals', text: 'Check this listing on Classic Rentals', url: item ? `${location.origin}${item.url}` : location.href };
  if (navigator.share) { try { await navigator.share(data); } catch {} } else toast('Share not supported. Use Copy link.');
});

el('quickExplore')?.addEventListener('click', () => document.querySelector('#featured').scrollIntoView({ behavior: 'smooth' }));
el('airbnbBtn')?.addEventListener('click', () => { state.category = 'shortstay'; state.q = 'Airbnb'; state.sort = 'featured'; state.newestLimit = 8; render(); document.querySelector('#featured').scrollIntoView({ behavior: 'smooth', block: 'start' }); toast('Showing Airbnb-style short stays.'); });
el('viewFavs').addEventListener('click', () => {
  const favs = LISTINGS.filter((x) => state.favorites.has(x.id));
  if (!favs.length) return toast('No favorites yet. Tap the heart on any listing.', true);
  state.newestLimit = 9999;
  el('newestGrid').innerHTML = favs.map(cardHTML).join('');
  document.querySelector('#newest').scrollIntoView({ behavior: 'smooth' });
  toast('Showing favorites.');
});

for (const [id, handler] of [
  ['supportBtn', () => toast('Support: connect this to your contact page or live chat.')],
  ['reportBtn', () => toast('Open any listing and use Report to flag it.')],
  ['termsBtn', () => toast('Connect this to your terms and privacy page.')],
  ['aboutBtn', () => toast('Connect this to your about page.')],
]) {
  const node = el(id); if (node) node.addEventListener('click', (e) => { e.preventDefault(); handler(); });
}

populateDynamicAreas();
updateHeroStats();
render();
startHero();
</script>
</body>
</html>
