<%
  const safeCurrentUser = typeof currentUser !== 'undefined' ? currentUser : (typeof locals !== 'undefined' && typeof locals.currentUser !== 'undefined' ? locals.currentUser : null);
  const safeYear = typeof year !== 'undefined' ? year : new Date().getFullYear();
%>
<footer class="footer">
  <div class="wrap footerGrid">
    <div>
      <div class="brandBlock footerBrand">
        <span class="brandLogo">CR</span>
        <span>
          <strong>Classic Rentals</strong>
          <small>Premium rentals platform</small>
        </span>
      </div>
      <p class="footerCopy">Cars, houses, land, shops, offices and short-stays in Juba with a faster, cleaner and more trusted search experience.</p>
      <div class="pillRow">
        <span class="pill">Verified listings</span>
        <span class="pill">Agent-ready</span>
        <span class="pill">Mobile friendly</span>
      </div>
    </div>
    <div>
      <h4>Explore</h4>
      <p><a href="/listings">All listings</a></p>
      <p><a href="/listings?category=house">Houses</a></p>
      <p><a href="/listings?category=car">Cars</a></p>
      <p><a href="/listings?category=land">Land</a></p>
    </div>
    <div>
      <h4>Account</h4>
      <% if (safeCurrentUser) { %>
        <p><a href="/dashboard">Dashboard</a></p>
        <p><a href="/listings/create">Post listing</a></p>
        <p><a href="/listings/manage">Manage listings</a></p>
      <% } else { %>
        <p><a href="/auth/login">Login</a></p>
        <p><a href="/auth/register">Register</a></p>
      <% } %>
    </div>
    <div>
      <h4>Contact</h4>
      <p><a href="tel:+256781977217">+256 781 977 217</a></p>
      <p><a href="tel:+256776169893">+256 776 169 893</a></p>
      <p><a href="mailto:info@classicrentals.com">info@classicrentals.com</a></p>
      <p>Juba, South Sudan</p>
    </div>
  </div>
  <div class="wrap footerBottom">
    <p>© <%= safeYear %> Classic Rentals. All rights reserved.</p>
  </div>
  <div id="toast" class="toast" aria-live="polite"></div>
  <script src="/js/home.js"></script>
</footer>
</body>
</html>