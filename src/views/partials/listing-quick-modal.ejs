<div class="modalBack" id="listingModal" aria-hidden="true">
  <div class="listingModal modal premiumModal" role="dialog" aria-modal="true" aria-label="Listing details">
    <div class="modalTop premiumModalTop">
      <div>
        <div class="sectionLabel">Quick view</div>
        <b id="modalTitle">Listing</b>
      </div>
      <button class="modalClose" id="closeListingModal" aria-label="Close details" type="button">×</button>
    </div>
    <div class="modalGrid premiumModalGrid">
      <div class="modalMediaCard">
        <img id="modalImage" src="/img/placeholder.jpg" alt="Listing image">
      </div>
      <div class="modalInfoCard">
        <div class="pillRow" id="modalBadges"></div>
        <div class="premiumModalPriceRow">
          <div>
            <div class="modalPriceLine"><span id="modalPrice">USD 0</span> <small id="modalUnit">/month</small></div>
            <div class="muted" id="modalLocation">Juba</div>
          </div>
          <button class="fav" id="modalFav" type="button" aria-label="Save listing">♥</button>
        </div>
        <div class="modalMetaGrid" id="modalMeta"></div>
        <div class="modalDescription" id="modalDescription">—</div>
        <div class="actionRow modalActionRow">
          <button class="btn alt" id="openInquiryBtn" type="button">Send inquiry</button>
          <a class="btn" id="modalOpenLink" href="/listings">Open full page</a>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modalBack" id="inquiryModal" aria-hidden="true">
  <div class="listingModal modal premiumModal premiumModalNarrow" role="dialog" aria-modal="true" aria-label="Send inquiry">
    <div class="modalTop premiumModalTop">
      <div>
        <div class="sectionLabel">Inquiry</div>
        <b>Contact about this listing</b>
      </div>
      <button class="modalClose" id="closeInquiryModal" aria-label="Close inquiry" type="button">×</button>
    </div>
    <form id="homeInquiryForm" class="formGrid">
      <input class="input" type="text" name="name" placeholder="Your name" value="<%= currentUser ? `${currentUser.firstName || ''} ${currentUser.lastName || ''}`.trim() : '' %>">
      <input class="input" type="email" name="email" placeholder="Email" value="<%= currentUser?.email || '' %>">
      <input class="input" type="text" name="phone" placeholder="Phone" value="<%= currentUser?.phone || '' %>">
      <textarea class="input" name="message" rows="5" placeholder="Tell the owner what you want to know"></textarea>
      <button class="btn block" type="submit">Send inquiry</button>
    </form>
  </div>
</div>
